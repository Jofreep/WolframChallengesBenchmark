Notebook[{
Cell["Quick Start", "Title",ExpressionUUID->"b1e61fd5-1b97-4670-a887-fdd73d1b4e0d"],

Cell["Load the paclet", "Section",ExpressionUUID->"3b1d8020-6e69-4923-944a-785581ee99b8"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<JofreEspigulePons`WolframChallengesBenchmark`\>\"",
   "]"}]], "Input",ExpressionUUID->"040140d7-e811-40f4-b314-13be7a06cbe6"],

Cell["Run a smoke benchmark", "Section",ExpressionUUID->"baaa3b76-0451-451b-8127-b34810e22162"],

Cell["\<\
Build a tiny challenge set + expected-output bank, then evaluate an \
in-process candidate solution.  This is the shape every larger run follows.\
\>", "Text",ExpressionUUID->"cf6c737d-82ec-4ce8-88ac-364142f9e11d"],

Cell[BoxData[
 RowBox[{"RunBenchmark", "[", 
  RowBox[{
   RowBox[{"<|", 
    RowBox[{"\"\<Sum\>\"", "->", "\"\<Sum\>\""}], "|>"}], ",", 
   RowBox[{"<|", 
    RowBox[{"\"\<Sum\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<challengeName\>\"", "->", "\"\<Sum\>\""}], ",", 
        RowBox[{"\"\<input\>\"", "->", 
         RowBox[{"HoldComplete", "[", 
          RowBox[{"f", "[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ","}]}]}]}]}], 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\"\<expected\>\"", "->", "3"}], ",", 
       RowBox[{"\"\<metadata\>\"", "->", 
        RowBox[{"<|", "|>"}]}]}], "|>"}], "}"}], "|>"}], ",", 
   RowBox[{"<|", 
    RowBox[{"\"\<Sum\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{"\"\<code\>\"", "->", "\"\<f[a_,b_]:=a+b\>\""}], "|>"}]}], 
    "|>"}], ",", 
   RowBox[{"\"\<Model\>\"", "->", "\"\<local/smoke\>\""}], ",", 
   RowBox[{"\"\<IsolationMode\>\"", "->", "\"\<InProcess\>\""}]}], 
  "]"}]], "Input",ExpressionUUID->"0d600e87-d6e0-4e4a-a84d-09b078a95141"],

Cell["Generate candidate solutions from a model", "Section",ExpressionUUID->"d355c98e-fa06-447a-9279-da5001250526"],

Cell["Requires OPENROUTER_API_KEY in the environment.", "Text",ExpressionUUID->"1d412f94-0e47-49d6-9117-fc82c93ba2ba"],

Cell[BoxData[
 RowBox[{"GenerateSolutions", "[", 
  RowBox[{"challenges", ",", "testBank", ",", "<|", 
   RowBox[{"\"\<Model\>\"", "->", "\"\<anthropic/claude-opus-4\>\""}], "|>"}],
   "]"}]], "Input",ExpressionUUID->"bfadb68a-9a1f-4659-9e88-acf5dbcc8fe1"]
},
TaggingRules->{
 "Metadata" -> <|
   "title" -> "Quick Start", "type" -> "Tutorial", "paclet" -> 
