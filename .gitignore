# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Wolfram
*.bak
*~

# Paclet build artifacts (leave source, drop built bundles)
*.paclet
WolframChallengesLLMBenchmarkPaclet/Build/

# Python cache (in case anyone drops scripts here)
__pycache__/
*.pyc
*.pyo

# Local environment (API keys live in env vars, but be safe)
.env
.env.*
*.key
*credentials*
config/secrets.json

# Run artifacts: per-run subdirectories, generate.jsonl, *.stdout.log,
# *.stderr.log.  Authoritative records (run.json, results.wxf) are
# regenerated by every run; nothing in runs/ should be tracked.  Keep
# the directory itself via runs/.gitkeep so scripts can write into it.
#
# Note: a stripped, safe-to-share copy of the per-model results lives
# at data/results/<modelSlug>.json (tracked, written by
# scripts/PublishResults.wls).  Those files carry summary + perChallenge
# + perTest pass/fail \[LongDash] no LLM-generated solution source \[LongDash] and
# are what the public dashboards read from.  The full runs/ tree is
# only ever needed locally on the machine that ran the benchmark.
runs/*
!runs/.gitkeep

# Built dashboard site \[LongDash] regenerated by scripts/BuildSite.wls
# and by .github/workflows/publish-dashboards.yml on push.  The Pages
# workflow uploads it as an artifact and deploys it; no value in
# tracking it in git.
_site/

# Temp/scratch
tmp/
scratch/
*.tmp

# Legacy-migration archive (if/when created)
.legacy-archive/

# Private benchmark data \[LongDash] canonical solutions, held-out tests, etc.
# Defense-in-depth: keep these out of git so they can't leak via
# screenshares, shared zips, or downstream forks.
private/

# Model-generated solutions \[LongDash] one .wl per challenge per model.
# These are LLM outputs and may carry the provider's terms of service /
# IP constraints; we keep them off git so the public repo doesn't
# redistribute them.  Local copies stay on the developer's machine and
# are sufficient for grading; a colleague who clones the public repo
# brings their own (via scripts/GenerateSolutions.wls).
solutions/*/
!solutions/.gitkeep
