# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Wolfram
*.bak
*~

# Paclet build artifacts (leave source, drop built bundles)
*.paclet
WolframChallengesLLMBenchmarkPaclet/Build/

# Python cache (in case anyone drops scripts here)
__pycache__/
*.pyc
*.pyo

# Local environment (API keys live in env vars, but be safe)
.env
.env.*
*.key
*credentials*
config/secrets.json

# Log files from long-running benchmark invocations.
# The authoritative per-run record is runs/<runId>/{run.json,results.wxf};
# the *.stdout.log files are just the tee'd terminal output and bloat git.
runs/*.stdout.log
runs/*.stderr.log

# Temp/scratch
tmp/
scratch/
*.tmp

# Legacy-migration archive (if/when created)
.legacy-archive/

# Private benchmark data \[LongDash] canonical solutions, held-out tests, etc.
# Defense-in-depth: even on a private repo we keep these out of git so they
# can't leak via screenshares, shared zips, or downstream forks.
private/
