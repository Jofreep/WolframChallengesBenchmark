Notebook[{

Cell[CellGroupData[{
Cell["Wolfram Challenges Benchmark", "Title",ExpressionUUID->"61d6989b-b9d0-422f-8852-aa7503373f68"],

Cell["\<\
Interactive driver for the ChallengesBenchmark paclet. This notebook is \
equivalent to scripts/RunBenchmark.wls but with a live dashboard and an \
analysis section you can re-run cell by cell.\
\>", "Text",ExpressionUUID->"5370f6dc-9af8-4afc-9ddb-e2a85f197af9"],

Cell[CellGroupData[{

Cell["1. Load the paclet", "Section",ExpressionUUID->"4aa1c634-e8b3-4fe3-a068-dcf5e5a8d2c3"],

Cell["\<\
Assumes this notebook lives at the repo root. Re-run this cell whenever you \
edit a package file.\
\>", "Text",ExpressionUUID->"9fca388a-5ae5-4814-8aae-02629868f3e3"],

Cell["\<\
SetDirectory[NotebookDirectory[]];
PrependTo[$Path, NotebookDirectory[]];
Get[FileNameJoin[{NotebookDirectory[], \"ChallengesBenchmark\", \
\"ChallengesBenchmark.wl\"}]];\
\>", "Input",
 CellLabel->
  "In[2815]:=",ExpressionUUID->"f08820c9-337a-47d9-8d83-3ab925864516"],

