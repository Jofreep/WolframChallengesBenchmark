Cell[CellGroupData[{

Cell["11. Analysis \[LongDash] slowest / fastest", "Section",ExpressionUUID->"e052a82f-6552-4c7a-ac86-ba60c1d52945"],

Cell[CellGroupData[{

Cell["\<\
slowest = Reverse @ SortBy[run[\"results\"], #[\"durationSec\"] &];
Dataset[
  Map[
    <|\"testId\" -> #[\"testId\"],
      \"status\" -> #[\"status\"],
      \"passed\" -> #[\"passed\"],
      \"durationSec\" -> #[\"durationSec\"]|> &,
    Take[slowest, UpTo[15]]
  ]
]\
\>", "Input",
 CellLabel->
  "In[2858]:=",ExpressionUUID->"4c2c086d-681b-44cd-987b-908a00f29d1f"],

