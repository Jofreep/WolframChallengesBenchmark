Cell[CellGroupData[{

Cell["9. Analysis \[LongDash] per-challenge grid", "Section",ExpressionUUID->"1af380c0-a8c7-4439-b436-727385805ea6"],

Cell[CellGroupData[{

Cell["\<\
perChallenge = GroupBy[run[\"results\"], #[\"challengeName\"] &];
rows = KeyValueMap[
  Function[{name, rs},
    <|\"challenge\" -> name,
      \"tests\"     -> Length[rs],
      \"passed\"    -> Count[rs, _?(#[\"passed\"] &)],
      \"passRate\"  -> N[Count[rs, _?(#[\"passed\"] &)] / Length[rs]],
      \"avgSec\"    -> N[Mean[#[\"durationSec\"] & /@ rs]],
      \"statuses\"  -> Counts[#[\"status\"] & /@ rs]|>
  ],
  perChallenge
];
Dataset[SortBy[rows, -#[\"passRate\"] &]]\
\>", "Input",
 CellLabel->
  "In[2852]:=",ExpressionUUID->"cb7d310e-fc41-4d7f-bc55-cb96579b472f"],

