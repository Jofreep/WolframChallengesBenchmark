Cell[CellGroupData[{

Cell["13. Analysis \[LongDash] diff against a baseline", "Section",ExpressionUUID->"f93f3318-066c-4d5f-8de0-37b201b9a1b6"],

Cell["\<\
Set baselineDir to a previous runs/<runId> directory to compare.\
\>", "Text",ExpressionUUID->"46e8589f-3623-4505-bd83-255620f946bd"],

Cell[CellGroupData[{

Cell["\<\
baselineDir = FileNameJoin[{NotebookDirectory[], \"runs\", \
\"INSERT-RUN-ID-HERE\"}];

If[DirectoryQ[baselineDir],
  Module[{meta, res, base, diff},
    meta = Import[FileNameJoin[{baselineDir, \"run.json\"}], \"RawJSON\"];
    res  = Import[FileNameJoin[{baselineDir, \"results.wxf\"}], \"WXF\"];
    base = <|\"runId\" -> meta[\"runId\"], \"results\" -> res|>;
    diff = ChallengesBenchmark`DiffRuns[base, run];
    Column[{
      Grid[{
        {\"baseline\",    diff[\"baseline\"]},
        {\"new\",         diff[\"new\"]},
        {\"regressions\", Length @ diff[\"regressions\"]},
        {\"fixes\",       Length @ diff[\"fixes\"]},
        {\"newTests\",    Length @ diff[\"newTests\"]},
        {\"missing\",     Length @ diff[\"missingTests\"]}
      }, Frame -> All, Alignment -> {{Left, Right}}],
      If[diff[\"regressions\"] =!= {},
        Column[{Style[\"Regressions:\", Bold],
                Column[diff[\"regressions\"]]}],
        Style[\"No regressions.\", Darker[Green]]
      ]
    }]
  ],
  Style[\"Edit baselineDir above to point at a previous run.\", Italic]
]\
\>", "Input",
 CellLabel->
  "In[2862]:=",ExpressionUUID->"edb07d34-9c49-4f86-ac87-df5dd5a2ca69"],

Cell[BoxData[
 StyleBox["\<\"Edit baselineDir above to point at a previous run.\"\>",
  StripOnInput->False,
  FontSlant->Italic]], "Output",
 CellChangeTimes->{3.98561819759429*^9},
 CellLabel->
  "Out[2864]=",ExpressionUUID->"a1ba7561-10dd-4b38-9b06-fbf5a642ed1b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["14. Analysis \[LongDash] model comparison (optional)", "Section",ExpressionUUID->"63fdd1d3-1584-426f-a1ea-6a5af3b1d7c1"],

Cell["\<\
Sweep every runs/<runId> in a directory and plot pass rates by model.\
\>", "Text",ExpressionUUID->"cf0081b3-a821-4163-9298-6de906107a10"],

Cell["\<\
allRunDirs = FileNames[\"run-*\", FileNameJoin[{NotebookDirectory[], \
\"runs\"}]];
allMetas = Quiet @ Map[
  Import[FileNameJoin[{#, \"run.json\"}], \"RawJSON\"] &,
  allRunDirs
];
modelRows = Select[allMetas, KeyExistsQ[#, \"summary\"] &];
Dataset[
  SortBy[
    Map[
      <|\"runId\"    -> #[\"runId\"],
        \"model\"    -> #[\"model\"],
        \"finishedAt\" -> Lookup[#, \"finishedAt\", \"?\"],
        \"passed\"   -> #[\"summary\", \"passed\"],
        \"total\"    -> #[\"summary\", \"total\"],
        \"passRate\" -> #[\"summary\", \"passRate\"]|> &,
      modelRows
    ],
    -#[\"passRate\"] &
  ]
]\
\>", "Input",ExpressionUUID->"68847e2f-961c-494e-a1a7-c26576c6a54f"],

Cell["\<\
If[Length[modelRows] > 0,
  BarChart[
    AssociationMap[#[\"summary\", \"passRate\"] &, modelRows] /.
      (k_ -> v_) :> (k[\"model\"] <> \"/\" <> StringTake[k[\"runId\"], -6] -> \
v),
    ChartLabels -> Placed[Automatic, Above],
    PlotLabel -> \"Pass rate by run\",
    ImageSize -> 700,
    BarOrigin -> Left],
  \"No runs found.\"
]\
\>", "Input",ExpressionUUID->"85244c95-825a-4cac-b25f-8f8f0e6da352"]
}, Open  ]],

