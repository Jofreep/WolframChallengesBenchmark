Cell[CellGroupData[{

Cell["10. Analysis \[LongDash] duration distribution", "Section",ExpressionUUID->"270bf186-b20a-4eed-80d8-3fc65e1352d9"],

Cell[CellGroupData[{

Cell["\<\
durations = #[\"durationSec\"] & /@ run[\"results\"];
Row[{
  Histogram[durations, 30,
    PlotLabel -> \"Duration (seconds, all tests)\",
    AxesLabel -> {\"sec\", \"count\"},
    ImageSize -> 400],
  Histogram[Select[durations, # < Quantile[durations, 0.95] &], 30,
    PlotLabel -> \"Duration (< p95)\",
    AxesLabel -> {\"sec\", \"count\"},
    ImageSize -> 400]
}]\
\>", "Input",
 CellLabel->
  "In[2855]:=",ExpressionUUID->"19340f9c-3994-4f49-b072-74376ea0a5e5"],

