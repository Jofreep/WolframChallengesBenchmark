"\<\"Varignon[{{ax_?NumericQ,ay_?NumericQ},{bx_?NumericQ,by_?NumericQ},{cx_?\
NumericQ,cy_?NumericQ},{dx_?NumericQ,dy_?NumericQ}}]:=Module[{midpoints,area},\
midpoints={({ax,ay}+{bx,by})/2,({bx,by}+{cx,cy})/2,({cx,cy}+{dx,dy})/2,({dx,\
dy}+{ax,ay})/2};area=Abs[Det[{midpoints[[2]]-midpoints[[1]],midpoints[[4]]-\
midpoints[[1]]}]];area]\"\>"}], ",", 
