     ",", "\"\<BubbleSortSteps[list:{__Integer}]:=Module[{s=list,n=Length[\
list],steps},steps={s};Do[Do[If[s[[j]]>s[[j+1]],s[[{j,j+1}]]=s[[{j+1,j}]]];\
AppendTo[steps,s],{j,1,n-1}],{i,1,n}];steps]\>\"", 
     ",", "\"\<ButterflyString[str_String] := str <> StringReverse[str]\>\"", 
     ",", "\"\<```wolfram\\nRowAndIteration[list_] := Module[{current = list, \
seen = <|list -> 0|>, iter = 0, next},\\n  While[True,\\n    iter++;\\n    \
next = Mod[current + RotateLeft[current], 10];\\n    If[KeyExistsQ[seen, \
next], Return[{next, iter}]];\\n    seen[next] = iter;\\n    current = \
next;\\n  ]\\n]\\n```\>\"", 
     ",", "\"\<```wolfram\\nRGBtoCMYK[{r_/;0\[LessEqual]r\[LessEqual]1,g_/;0\
\[LessEqual]g\[LessEqual]1,b_/;0\[LessEqual]b\[LessEqual]1}]:=With[{k=1-Max[r,\
