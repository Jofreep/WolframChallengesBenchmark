Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"AliquotSequence\"\>", 
    "\[Rule]", "\<\"AliquotSequence[num_Integer?Positive] := Module[{f = \
DivisorSigma[1, #] - # &, seq = {num}, x = num},\\n  While[Length[seq] < 100 \
&& x =!= 1,\\n    x = f[x];\\n    If[MemberQ[seq, x], Break[]];\\n    \
AppendTo[seq, x]\\n  ];\\n  seq\\n]\"\>"}], ",", 
   RowBox[{"\<\"AlmostPalindromes\"\>", 
    "\[Rule]", "\<\"AlmostPalindrome[n_Integer?Positive] := \
Select[DictionaryLookup[RegularExpression[\\\"^.{\\\" <> ToString[n] <> \
\\\"}$\\\"]], !PalindromeQ[#] && AnyTrue[Range[StringLength[#]], \
PalindromeQ@StringDelete[#, {#2}] &] &]\"\>"}], ",", 
   RowBox[{"\<\"AlmostRepeatingPrimes\"\>", 
    "\[Rule]", "\<\"RepeatandEndingPrimes[rep_, end_] := Select[FromDigits /@ \
Table[Join[ConstantArray[rep, n], {end}], {n, 1, 30}], PrimeQ]\"\>"}], ",", 
   RowBox[{"\<\"AnagramWords\"\>", 
    "\[Rule]", \
"\<\"Anagrams[s_String]:=Sort@DictionaryLookup[RegularExpression[\\\"(?i)\\\\\
\\\\Q\\\"<>StringJoin[Sort@Characters[s]]<>\\\"\\\\\\\\E\\\"],IgnoreCase->\
True,TransformationFunctions->{Sort@Characters[#]&}]\"\>"}], ",", 
   RowBox[{"\<\"AscendingSublists\"\>", 
    "\[Rule]", \
"\<\"AscendingSublists[list:{___Integer}]:=Select[Split[list,#1<#2&],Length[#]\
>=2&]\"\>"}], ",", 
   RowBox[{"\<\"BabbageSquares\"\>", 
    "\[Rule]", "\<\"AverageElevation[lat_ /; -90 <= lat <= 90] := \
Round[Mean[QuantityMagnitude@UnitConvert[GeoElevationData[GeoPosition[{lat, \
#}]] & /@ Range[-180, 180], \\\"Feet\\\"]], 100]\"\>"}], ",", 
   RowBox[{"\<\"BasebPalindromicNumbers\"\>", 
    "\[Rule]", "\<\"BabbageSquares[word_String /; StringLength[word] == 4] := \
Module[\\n  {w = ToLowerCase[word], words, assoc, c1, c2, c3, res},\\n  words \
= Select[ToLowerCase /@ WordList[], StringLength[#] == 4 && StringMatchQ[#, \
LetterCharacter ..] &];\\n  assoc = GroupBy[words, StringTake[#, 1] &];\\n  \
{c1, c2, c3} = Characters[StringDrop[w, 1]];\\n  res = Reap[\\n     Do[\\n    \
  With[{r2 = r},\\n       If[StringTake[r2, {2}] === c1,\\n        Do[\\n     \
    With[{r3 = s},\\n          If[StringTake[r3, {2}] === c2 && \
StringTake[r3, {3}] === StringTake[r2, {3}],\\n           Do[\\n            \
With[{r4 = t},\\n             If[\\n              StringTake[r4, {2}] === c3 \
&&\\n               StringTake[r4, {3}] === StringTake[r3, {4}] &&\\n         \
      StringTake[r4, {4}] === StringTake[r2, {4}],\\n              \
Sow[Grid[Characters /@ {w, r2, r3, r4}]]\\n              ]\\n             \
],\\n            Lookup[assoc, StringTake[r2, {4}], {}]\\n            ]\\n    \
       ]\\n          ],\\n         Lookup[assoc, c2, {}]\\n         ]\\n      \
  ]\\n       ],\\n      {r, Lookup[assoc, c1, {}]}\\n      ]\\n     ][[2, \
1]];\\n  SortBy[DeleteDuplicates[res], First @* Normal]\\n  ]\"\>"}], ",", 
   RowBox[{"\<\"BubbleSort\"\>", 
    "\[Rule]", "\<\"PalindromicNumbers[b_Integer] /; b > 1 := \
Select[Range[1000], PalindromeQ[IntegerDigits[#, b]] &]\"\>"}], ",", 
   RowBox[{"\<\"CellularAutomaton\"\>", 
    "\[Rule]", "\<\"CaesarDecrypt[cipherText_String?LowerCaseQ, key_Integer] \
/; 1 <= key <= 25 := FromCharacterCode[Mod[ToCharacterCode[cipherText] - 97 - \
key, 26] + 97]\"\>"}], ",", 
   RowBox[{"\<\"ColorConversion\"\>", 
    "\[Rule]", "\<\"BubbleSortSteps[list : {__Integer}] := Module[{a = list, \
n = Length[list], res = {list}},\\n  Do[\\n    Do[\\n      If[a[[j]] > a[[j + \
1]], a[[{j, j + 1}]] = a[[{j + 1, j}]]];\\n      AppendTo[res, a],\\n      \
{j, 1, n - 1}\\n    ],\\n    {n}\\n  ];\\n  res\\n]\"\>"}], ",", 
   RowBox[{"\<\"CombineNOnes\"\>", 
    "\[Rule]", \
"\<\"ButterflyString[str_String]:=StringJoin[str,StringReverse[str]]\"\>"}], ",", 
   RowBox[{"\<\"ConstantDigitSum\"\>", 
    "\[Rule]", "\<\"RowAndIteration[list_] := Module[{f, seen = <||>, row = \
list, i = 0},\\n  f[v_] := Mod[v + RotateLeft[v], 10];\\n  seen[row] = 0;\\n  \
While[True,\\n    i++;\\n    row = f[row];\\n    If[KeyExistsQ[seen, row], \
Return[{row, i}]];\\n    seen[row] = i;\\n  ]\\n]\"\>"}], ",", 
   RowBox[{"\<\"DeriffleAList\"\>", 
    "\[Rule]", "\<\"RGBtoCMYK[{r_ /; 0 <= r <= 1, g_ /; 0 <= g <= 1, b_ /; 0 \
<= b <= 1}] := Module[{k = 1 - Max[{r, g, b}]}, If[k == 1, {0, 0, 0, 1}, \
N[{(1 - r - k)/(1 - k), (1 - g - k)/(1 - k), (1 - b - k)/(1 - k), \
k}]]]\"\>"}], ",", 
   RowBox[{"\<\"DigitFrequencyForPi\"\>", 
    "\[Rule]", "\<\"NumbersFromOnes[n_Integer] /; n > 1 := NumbersFromOnes[n] \
= Union @ Flatten @ Table[\\n   With[{a = NumbersFromOnes[k], b = \
NumbersFromOnes[n - k]},\\n    Join[Flatten[Outer[Plus, a, b]], \
Flatten[Outer[Times, a, b]]]\\n   ],\\n   {k, 1, Quotient[n, \
2]}\\n];\\nNumbersFromOnes[1] = {1};\"\>"}], ",", 
   RowBox[{"\<\"DiscreteSpiral\"\>", 
    "\[Rule]", "\<\"Composite[n_Integer?Positive] := n + PrimePi[n + Floor[2 \
n Log[n + 2]]] // FixedPoint[# + PrimePi[#] &, #] &\"\>"}], ",", 
   RowBox[{"\<\"FactorialDigitFrequency\"\>", 
    "\[Rule]", "\<\"ConstantDigitSum[m_Integer, n_Integer, s_Integer] := \
Select[Range[m, n], Total[IntegerDigits[#]] == s &]\"\>"}], ",", 
   RowBox[{"\<\"FarthestWords\"\>", 
    "\[Rule]", "\<\"NumberOfLatticePaths[n_Integer] := Binomial[2 n - 2, n - \
1]\"\>"}], ",", 
   RowBox[{"\<\"FewestNumberOfCoins\"\>", 
    "\[Rule]", \
"\<\"TwinPrimeCount[n_Integer?Positive]:=Count[Differences[Prime[Range[\
PrimePi[n]]]],2]\"\>"}], ",", 
   RowBox[{"\<\"FindGoldbachPartitions\"\>", 
    "\[Rule]", "\<\"PalindromicSubsequenceCount[str_String] := Module[{c = \
Characters[str], n, dp, i, j},\\n  n = Length[c];\\n  If[n == 0, \
Return[0]];\\n  dp = ConstantArray[0, {n, n}];\\n  Do[dp[[i, i]] = 1, {i, \
n}];\\n  Do[\\n    Do[\\n      dp[[i, j]] = dp[[i + 1, j]] + dp[[i, j - 1]] - \
dp[[i + 1, j - 1]] + If[c[[i]] === c[[j]], dp[[i + 1, j - 1]] + 1, 0],\\n     \
 {i, 1, n - len + 1};\\n      j = i + len - 1\\n    ],\\n    {len, 2, n}\\n  \
];\\n  dp[[1, n]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"ForbiddenSubstrings\"\>", 
    "\[Rule]", "\<\"CountSquares[pts_List] := Module[{u = \
DeleteDuplicates[pts], s, n},\\n  s = AssociationThread[u -> True];\\n  n = \
Length[u];\\n  Total@Table[\\n    With[{p = u[[i]], q = u[[j]], dx = u[[j, \
1]] - u[[i, 1]], dy = u[[j, 2]] - u[[i, 2]]},\\n      Boole[KeyExistsQ[s, \
{p[[1]] - dy, p[[2]] + dx}] && KeyExistsQ[s, {q[[1]] - dy, q[[2]] + dx}]]\\n  \
  ],\\n    {i, 1, n - 1}, {j, i + 1, n}\\n  ]/2\\n]\"\>"}], ",", 
   RowBox[{"\<\"IntegerNameLengths\"\>", 
    "\[Rule]", "\<\"Deriffle[s_List] := s[[#]] & /@ {1 ;; ;; 2, 2 ;; ;; \
2}\"\>"}], ",", 
   RowBox[{"\<\"IntegersWithGivenDigitSums\"\>", 
    "\[Rule]", "\<\"ClockIdentities[time_String] := Module[\\n  {d = \
ToExpression /@ Characters[time], n, ops, eval},\\n  n = Length[d];\\n  \
eval[list_] := Catch@Fold[\\n     Function[{a, opb},\\n       If[opb[[1]] === \
\\\"/\\\",\\n         If[opb[[2]] === 0, Throw[None], a/opb[[2]]],\\n         \
If[opb[[1]] === \\\"\\\", 10 a + opb[[2]], opb[[1]][a, opb[[2]]]]\\n       \
]\\n     ],\\n     First[list],\\n     Rest[list]\\n   ];\\n  ops = \
{\\\"\\\", Plus, Subtract, Times, \\\"/\\\"};\\n  Count[\\n    Flatten[\\n    \
  Table[\\n        With[{leftOps = Tuples[ops, k - 1], rightOps = Tuples[ops, \
n - k - 1]},\\n          Flatten[\\n            Table[\\n              \
With[\\n                {\\n                  lv = eval@MapThread[List, {d[[1 \
;; k]], Prepend[lo, \\\"\\\"]}],\\n                  rv = \
eval@MapThread[List, {d[[k + 1 ;; n]], Prepend[ro, \\\"\\\"]}]\\n             \
   },\\n                If[lv === None || rv === None, Nothing, lv == rv]\\n  \
            ],\\n              {lo, leftOps}, {ro, rightOps}\\n            ],\
\\n            1\\n          ]\\n        ],\\n        {k, 1, n - 1}\\n      \
],\\n      3\\n    ],\\n    True\\n  ]\\n]\"\>"}], ",", 
   RowBox[{"\<\"IteratedRomanNumeralization\"\>", 
    "\[Rule]", "\<\"DigitalRoot[n_Integer] /; n >= 0 := If[n == 0, 0, 1 + \
Mod[n - 1, 9]]\"\>"}], ",", 
   RowBox[{"\<\"JosephusProblem\"\>", 
    "\[Rule]", \
"\<\"DigitCountPi[n_Integer?Positive]:=DigitCount[RealDigits[N[Pi,n+1]][[1,2;;\
n+1]],10,Range[0,9]]\"\>"}], ",", 
   RowBox[{"\<\"LetterBank\"\>", 
    "\[Rule]", \
"\<\"DiscreteSpiral[n_Integer?Positive]:=Module[{dirs={{1,0},{0,1},{-1,0},{0,-\
1}},steps,seq},\\nsteps=Take[Flatten[Transpose[{Range[Ceiling[n/2]],Range[\
Ceiling[n/2]]}]],Ceiling[n/2]];\\nseq=Take[Flatten[MapThread[ConstantArray,{\
Take[dirs,Length[steps]],steps}],1],n];\\nFoldList[Plus,{0,0},seq]\\n]\"\>"}],
    ",", 
   RowBox[{"\<\"ListifyTheElementsOfAList\"\>", 
    "\[Rule]", "\<\"FactorialSortedDigits[n_Integer] /; n > 10 := Module[{c = \
ConstantArray[0, 10]},\\n Do[\\n  Scan[(c[[# + 1]]++) &, \
IntegerDigits[k!]],\\n  {k, n}\\n ];\\n First /@ SortBy[Transpose[{Range[0, \
9], c}], {Last, First}]\\n]\"\>"}], ",", 
   RowBox[{"\<\"LookAndSaySequence\"\>", 
    "\[Rule]", \
"\<\"FarthestWords[s_String]:=With[{w=WordList[]},Sort@Pick[w,Unitize[\
EditDistance[s,#]&/@w-Max[EditDistance[s,#]&/@w]],1]]\"\>"}], ",", 
   RowBox[{"\<\"MostDistinctLetters\"\>", 
    "\[Rule]", \
"\<\"Coins[{x__Integer?Positive},target_Integer?Positive]:=Module[\\n \
{vals={x},n,best,ways,v,i,new},\\n best=ConstantArray[Infinity,target+1];\\n \
ways=ConstantArray[{},target+1];\\n best[[1]]=0;\\n \
ways[[1]]={ConstantArray[0,Length[vals]]};\\n Do[\\n  v=vals[[i]];\\n  Do[\\n \
  If[best[[s-v+1]]<Infinity,\\n    new=MapAt[#1+1&,ways[[s-v+1]],{All,i}];\\n \
   If[best[[s-v+1]]+1<best[[s+1]],\\n     best[[s+1]]=best[[s-v+1]]+1;\\n     \
ways[[s+1]]=new,\\n     If[best[[s-v+1]]+1==best[[s+1]],\\n      \
ways[[s+1]]=Join[ways[[s+1]],new]\\n     ]\\n    ]\\n   ],\\n   \
{s,v,target}\\n  ],\\n  {i,n=Length[vals]}\\n ];\\n \
If[best[[target+1]]===Infinity,{},Sort[DeleteDuplicates[ways[[target+1]]]]]\\\
n]\"\>"}], ",", 
   RowBox[{"\<\"MultiplicationTable\"\>", 
    "\[Rule]", "\<\"GoldbachPartitions[n_Integer?EvenQ] /; n > 2 := \
Select[{#, n - #} & /@ Prime[Range[PrimePi[n/2]]], PrimeQ[#[[2]]] &]\"\>"}], ",", 
   RowBox[{"\<\"NextPermutation\"\>", 
    "\[Rule]", "\<\"ForbiddenSubstring[n_Integer?Positive, sub_String] /; \
SubsetQ[{\\\"A\\\", \\\"B\\\"}, Union[Characters[sub]]] := Module[\\n  {m = \
StringLength[sub], chars = Characters[sub], trans, out = {}, rec},\\n  If[m \
== 0, Return[{}]];\\n  trans = Table[\\n    Function[c,\\n      Module[{s = \
StringTake[StringJoin[Take[chars, k], {c}], -Min[m - 1, k + 1]]},\\n        \
LengthWhile[Range[Min[m - 1, StringLength[s]], 0, -1], StringTake[s, -#] === \
StringTake[sub, #] &] /. {} -> 0\\n      ]\\n    ],\\n    {k, 0, m - 1}\\n  \
];\\n  rec[pos_, state_, acc_] := If[\\n    pos > n,\\n    AppendTo[out, \
StringJoin[acc]],\\n    Do[\\n      With[{ns = trans[[state + 1]][c]},\\n     \
   If[ns < m, rec[pos + 1, ns, Append[acc, c]]]\\n      ],\\n      {c, {\\\"A\
\\\", \\\"B\\\"}}\\n    ]\\n  ];\\n  rec[1, 0, {}];\\n  out\\n]\"\>"}], ",", 
   RowBox[{"\<\"OddsBeforeEvens\"\>", 
    "\[Rule]", \
"\<\"NimWin[w_Integer?NonNegative,x_Integer?NonNegative,y_Integer?NonNegative,\
z_Integer?NonNegative]/;(w+x+y+z>0):=BitXor[w,x,y,z]!=0\"\>"}], ",", 
   RowBox[{"\<\"PairingCompatibleIntegers\"\>", 
    "\[Rule]", \
"\<\"FridayThe13ths[year_Integer?NonNegative]:=Count[DayName/@(DateObject[{\
year,#,13}]&/@Range[12]),Friday]\"\>"}], ",", 
   RowBox[{"\<\"Palindromes\"\>", 
    "\[Rule]", "\<\"GrayCode[n_Integer?NonNegative] := \
IntegerString[BitXor[n, BitShiftRight[n]], 2]\"\>"}], ",", 
   RowBox[{"\<\"PalindromicRomanNumerals\"\>", 
    "\[Rule]", "\<\"GrayscaleSpectrum[sequence_List] := Module[{min = \
Min[sequence], max = Max[sequence], d},\\n  d = max - min;\\n  Row[GrayLevel \
/@ N[If[d == 0, ConstantArray[0, Length[sequence]], (sequence - min)/d]]]\\n]\
\"\>"}], ",", 
   RowBox[{"\<\"PartitionsOfIncreasingLength\"\>", 
    "\[Rule]", "\<\"CountryRoundness[country : Entity[\\\"Country\\\", _]] := \
Module[\\n  {poly, polys, coords, area, disk},\\n  poly = country[\\\"Polygon\
\\\"] /. GeoPosition -> Identity /. {x_?NumericQ, y_?NumericQ} :> {y, x};\\n  \
polys = Cases[poly, _Polygon, Infinity];\\n  coords = Join @@ Cases[polys, \
Polygon[p_] :> Flatten[{p}, 1], Infinity];\\n  area = Total[Area /@ \
polys];\\n  disk = BoundingRegion[coords, \\\"MinDisk\\\"];\\n  \
N[area/Area[disk]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"PermutationIndex\"\>", 
    "\[Rule]", "\<\"IntegerNameSequence[n_Integer?Positive] := \
NestWhileList[StringLength@*IntegerName[#, \\\"Words\\\"] &, n, UnsameQ @@ # \
&, 2]\"\>"}], ",", 
   RowBox[{"\<\"PowerfulDigitFrequencies\"\>", 
    "\[Rule]", "\<\"FindWithGivenDigitSum[s_Integer?Positive] := \
Select[Range[999], Total[IntegerDigits[#]] == s &]\"\>"}], ",", 
   RowBox[{"\<\"PrimeFibonacciNumbers\"\>", 
    "\[Rule]", "\<\"IteratedRomanNumeralList[n_Integer?Positive] := Module[{x \
= n, seen = <||>, r, out = {}},\\n  While[! KeyExistsQ[seen, x],\\n    \
seen[x] = True;\\n    r = IntegerString[x, \\\"Roman\\\"];\\n    \
AppendTo[out, ToExpression[r, InputForm, HoldForm]];\\n    x = \
StringLength[r];\\n  ];\\n  out\\n]\"\>"}], ",", 
   RowBox[{"\<\"PythagoreanPrimes\"\>", 
    "\[Rule]", "\<\"JosephusList[men_Integer?Positive, skip_Integer?Positive] \
:= Module[{alive = Range[men], k = skip, i = 0, res = ConstantArray[0, men], \
t = 1, len = men},\\n  While[len > 0,\\n    i = Mod[i + k - 1, len] + 1;\\n   \
 res[[t]] = alive[[i]];\\n    alive = Delete[alive, i];\\n    len--;\\n    \
t++;\\n    i--;\\n  ];\\n  res\\n]\"\>"}], ",", 
   RowBox[{"\<\"RATSSequences\"\>", 
    "\[Rule]", \
"\<\"b[n_Integer?Positive]:=Nest[({#2,Mod[#2^4+1,2027]*PowerMod[#1,-1,2027],#\
3+1}&@@#)&,{1,2,1},n-1][[2]]\"\>"}], ",", 
   RowBox[{"\<\"ReasonablyCloseRectangle\"\>", 
    "\[Rule]", "\<\"CollatzLength[n_Integer] /; n > 0 := NestWhile[#/2 + \
Boole[OddQ[#]] (5 #/2 + 1) &, n, # != 1 &, 1, Infinity, -1] // Length // \
Subtract[#, 1] &\"\>"}], ",", 
   RowBox[{"\<\"RemoveIdenticalNeighbors\"\>", 
    "\[Rule]", "\<\"LetterBank[string_?LowerCaseQ] := Module[{c = \
Counts@Characters[string]},\\n  Sort@Select[WordList[], With[{wc = \
Counts@Characters[#]}, SubsetQ[Keys[c], Keys[wc]] && And @@ Thread[Lookup[wc, \
Keys[wc]] <= Lookup[c, Keys[wc]]]] &]\\n]\"\>"}], ",", 
   RowBox[{"\<\"RepeatFreeTernarySequences\"\>", 
    "\[Rule]", "\<\"Listify[l_List, n_Integer?Positive] := ConstantArray[#, \
n] & /@ l\"\>"}], ",", 
   RowBox[{"\<\"RomanNumeralsVersusDecimal\"\>", 
    "\[Rule]", \
"\<\"LongestReversedSubsequence[list:{__Integer}]:=Module[{n=Length[list],dp,\
i,j},\\ndp=ConstantArray[0,{n,n}];\\nDo[\\ndp[[i,i]]=1;\\n,{i,n}];\\nDo[\\nIf[\
list[[i]]===list[[j]],\\ndp[[i,j]]=If[i+1<=j-1,dp[[i+1,j-1]],0]+2,\\ndp[[i,j]]\
=Max[dp[[i+1,j]],dp[[i,j-1]]]\\n];\\n,{d,1,n-1},{i,1,n-d};j=i+d];\\ndp[[1,n]]\
\\n]\"\>"}], ",", 
   RowBox[{"\<\"Rotodromes\"\>", 
    "\[Rule]", "\<\"LookAndSay[n_Integer?Positive] := Module[{next},\\n  \
next[x_Integer] := FromDigits @ Flatten[({Length[#], First[#]} &) /@ \
Split[IntegerDigits[x]]];\\n  NestList[next, 1, n - 1]\\n]\"\>"}], ",", 
   RowBox[{"\<\"SilvermansSequence\"\>", 
    "\[Rule]", "\<\"MagicSquareQ[matrix_?MatrixQ] /; Equal @@ \
Dimensions[matrix] := Module[\\n  {n = Length[matrix], flat, s},\\n  flat = \
Flatten[matrix];\\n  s = n (n^2 + 1)/2;\\n  Sort[flat] === Range[n^2] &&\\n   \
And[\\n    Total /@ matrix === ConstantArray[s, n],\\n    Total /@ \
Transpose[matrix] === ConstantArray[s, n],\\n    Total[Diagonal[matrix]] == \
s,\\n    Total[Diagonal[Reverse[matrix]]] == s\\n   ]\\n]\"\>"}], ",", 
   RowBox[{"\<\"SingleDigitNumbers\"\>", 
    "\[Rule]", "\<\"LargestContiguousSum[numbers_List] := Fold[Function[{s, \
x}, {Max[x, s[[1]] + x], Max[s[[2]], Max[x, s[[1]] + x]]}], {First[numbers], \
First[numbers]}, Rest[numbers]][[2]]\"\>"}], ",", 
   RowBox[{"\<\"SpellWithChemicalElements\"\>", 
    "\[Rule]", "\<\"MaximumOverhang[n_Integer?Positive] := \
N[HarmonicNumber[n]/2, 6]\"\>"}], ",", 
   RowBox[{"\<\"SquarefreeTernarySequences\"\>", 
    "\[Rule]", "\<\"MostDistinctLetters[chars_List] := Module[{set = \
DeleteDuplicates@ToLowerCase[chars], words, counts, max},\\n  words = \
Select[WordList[], StringMatchQ[#, LetterCharacter ..] &];\\n  counts = \
Length[Intersection[set, DeleteDuplicates@Characters@ToLowerCase[#]]] & /@ \
words;\\n  max = Max[Prepend[counts, 0]];\\n  Sort@Pick[words, counts, \
max]\\n]\"\>"}], ",", 
   RowBox[{"\<\"SquareRootFloorDigits\"\>", 
    "\[Rule]", "\<\"FindLongestRomanNumeral[max_Integer?Positive] := \
First@First@MaximalBy[Range[max], {StringLength[RomanNumeral[#]], -#} \
&]\"\>"}], ",", 
   RowBox[{"\<\"SquareSequences\"\>", 
    "\[Rule]", \
"\<\"MultTable[{xmin_Integer,xmax_Integer},{ymin_Integer,ymax_Integer}] := \
With[{xs = Range[xmin, xmax], ys = Range[ymin, ymax]}, \
Prepend[MapThread[Prepend, {Outer[Times, xs, ys], xs}], Prepend[ys, \
\\\"\\\\[Times]\\\"]]]\"\>"}], ",", 
   RowBox[{"\<\"SumsToAnInteger\"\>", 
    "\[Rule]", "\<\"NextPermutation[p:{__Integer}] := Module[{a = p, n = \
Length[p], i, j},\\n  i = n - 1;\\n  While[i >= 1 && a[[i]] >= a[[i + 1]], \
i--];\\n  If[i < 1, Return[Sort[a]]];\\n  j = n;\\n  While[a[[j]] <= a[[i]], \
j--];\\n  a[[{i, j}]] = a[[{j, i}]];\\n  Join[a[[;; i]], Reverse[a[[i + 1 \
;;]]]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"WordsWithAGivenPrefix\"\>", 
    "\[Rule]", "\<\"LookAndSay[n_Integer] /; n >= 0 := FromDigits @ \
Flatten[Length[#], First[#]] & /@ Split[IntegerDigits[n]]\"\>"}], ",", 
   RowBox[{"\<\"TelephoneWords\"\>", 
    "\[Rule]", "\<\"WordsWithNVowels[n_Integer?NonNegative] := \
Count[StringCount[ToLowerCase[WordList[]], Alternatives @@ \
Characters[\\\"aeiou\\\"]], n]\"\>"}], ",", 
   RowBox[{"\<\"MostOccurringWeekdaysInAYear\"\>", 
    "\[Rule]", \
"\<\"OddBeforeEven[list:{__Integer}]:=Join[Select[list,OddQ],Select[list,\
EvenQ]]\"\>"}], ",", 
   RowBox[{"\<\"FizzBuzz\"\>", 
    "\[Rule]", "\<\"OneFingerDistance[s_String?LowerCaseQ] := Total[Max[0, \
Abs[Differences[ToCharacterCode[s]]] - 1]]\"\>"}], ",", 
   RowBox[{"\<\"PairsThatSumTo100\"\>", 
    "\[Rule]", \
"\<\"SumMatching[numbers:{_Integer..},sums:{_Integer..}]:=Module[\\n \
{n=Length[numbers],ord,vals,cnts,m,idx,valToPos,edges,adj,pairU,pairV,dist,\
freeU,bfs,dfs,matching,res={},usedV=<||>,u,v,a,b},\\n \
If[OddQ[n],Return[$Failed]];\\n ord=Ordering[numbers];\\n \
vals=numbers[[ord]];\\n cnts=Counts[vals];\\n m=Length[vals];\\n \
idx=AssociationThread[Range[m]->vals];\\n \
valToPos=Association@MapIndexed[#1->#2[[1]]&,vals];\\n \
edges=Association@Table[\\n   u->DeleteMissing@Map[\\n      Function[t,\\n    \
    a=t-idx[u];\\n        If[KeyExistsQ[valToPos,a],\\n          \
v=valToPos[a];\\n          If[v>u,v,Missing[]],\\n          Missing[]\\n      \
  ]\\n      ],\\n      DeleteDuplicates[sums]\\n    ],\\n   {u,m}\\n ];\\n \
adj=edges;\\n pairU=AssociationThread[Range[m]->ConstantArray[0,m]];\\n \
pairV=AssociationThread[Range[m]->ConstantArray[0,m]];\\n \
bfs:=Module[{q={},head=1,u,v},\\n   dist=<||>; freeU={};\\n   Do[\\n    \
If[pairU[u]==0,dist[u]=0;AppendTo[q,u];AppendTo[freeU,u],dist[u]=Infinity],\\\
n    {u,m}\\n   ];\\n   While[head<=Length[q],\\n    u=q[[head++]];\\n    Do[\
\\n     If[pairV[v]!=0&&Lookup[dist,pairV[v],Infinity]===Infinity,\\n       \
dist[pairV[v]]=dist[u]+1;\\n       AppendTo[q,pairV[v]]\\n     ],\\n     \
{v,adj[u]}\\n    ]\\n   ];\\n   AnyTrue[freeU,AnyTrue[adj[#],pairV[#2]==0&]&]\
\\n ];\\n dfs[u_]:=Module[{v,pu},\\n   Do[\\n    pu=pairV[v];\\n    \
If[pu==0||(Lookup[dist,pu,Infinity]==dist[u]+1&&dfs[pu]),\\n      pairU[u]=v; \
pairV[v]=u; Return[True]\\n    ],\\n    {v,adj[u]}\\n   ];\\n   \
dist[u]=Infinity;\\n   False\\n ];\\n \
While[bfs,Do[If[pairU[u]==0,dfs[u]],{u,freeU}]];\\n \
If[Count[Values[pairU],_?(#>0&)]!=m,Return[$Failed]];\\n Do[\\n  \
v=pairU[u];\\n  If[!KeyExistsQ[usedV,v],\\n    usedV[v]=True;\\n    a=idx[u]; \
b=idx[v];\\n    AppendTo[res,{a,b}]\\n  ],\\n  {u,m}\\n ];\\n \
If[Length[res]*2!=n,$Failed,res]\\n]\"\>"}], ",", 
   RowBox[{"\<\"GettingABasketballScore\"\>", 
    "\[Rule]", "\<\"Palindromize[str_String] := Module[{n = \
StringLength[str], rev = StringReverse[str], k},\\n  k = \
First@FirstPosition[Range[0, n], i_ /; StringTake[str, {i + 1, n}] === \
StringTake[rev, n - i], n];\\n  str <> StringTake[rev, {k + 1, n}]\\n]\"\>"}],
    ",", 
   RowBox[{"\<\"WordsBeginningAndEndingWithAGivenLetter\"\>", 
    "\[Rule]", "\<\"Palindrome[n_Integer] /; n > 0 := \
Select[DictionaryLookup[RegularExpression[\\\"^.{\\\" <> ToString[n] <> \
\\\"}$\\\"]], PalindromeQ]\"\>"}], ",", 
   RowBox[{"\<\"UpAndDownWords\"\>", 
    "\[Rule]", "\<\"RomanPalindromes[n_Integer] /; n > 0 := Select[Range[n], \
PalindromeQ[Characters[IntegerString[#, \\\"Roman\\\"]]] &]\"\>"}], ",", 
   RowBox[{"\<\"ThreeTriangularNumbers\"\>", 
    "\[Rule]", "\<\"PartitionLonger[l_List]:=TakeList[l,Range[Floor[(Sqrt[1+8 \
Length[l]]-1)/2]]]\"\>"}], ",", 
   RowBox[{"\<\"FourPointParabola\"\>", 
    "\[Rule]", \
"\<\"PermutationIndex[order_Integer?Positive,index_Integer?Positive] /; index \
<= order! := Module[{digits, available = Range[order], res = {}, i},\\n  \
digits = IntegerDigits[index - 1, MixedRadix[Reverse[Range[order]]], \
order];\\n  Do[\\n    i = digits[[j]] + 1;\\n    AppendTo[res, \
available[[i]]];\\n    available = Delete[available, i],\\n    {j, order}\\n  \
];\\n  res\\n]\"\>"}], ",", 
   RowBox[{"\<\"SmallFactorsOfLargeNumbers\"\>", 
    "\[Rule]", "\<\"PigLatin[text_String] := StringReplace[text, w : \
LetterCharacter .. :> Module[{s = w, p},\\n   p = StringPosition[s, \
RegularExpression[\\\"[aeiou]\\\"], 1];\\n   If[p === {},\\n    s,\\n    \
If[p[[1, 1]] == 1,\\n     s <> \\\"way\\\",\\n     StringDrop[s, p[[1, 1]] - \
1] <> StringTake[s, p[[1, 1]] - 1] <> \\\"ay\\\"\\n     ]\\n    ]\\n   \
]]\"\>"}], ",", 
   RowBox[{"\<\"EmirpsIsPrimesBackward\"\>", 
    "\[Rule]", \
"\<\"DigitFrequenciesInThePowersOfTwo[n_Integer?Positive]:=BinCounts[\
IntegerDigits[2^n],{0,10,1}]\"\>"}], ",", 
   RowBox[{"\<\"MaximumColorDistance\"\>", 
    "\[Rule]", "\<\"FibonacciPrimes[n_Integer?Positive] := \
Select[Fibonacci[Range[n]], PrimeQ]\"\>"}], ",", 
   RowBox[{"\<\"PrimeGaps\"\>", 
    "\[Rule]", "\<\"MakePureFunction[f_Symbol] := With[{dvs = DownValues[f], \
n = Unique[\\\"n$\\\"], a = Unique[\\\"a$\\\"]}, \
Function[Evaluate@Table[Unique[\\\"arg$\\\"], {n}], \
Replace[HoldComplete[f[Sequence @@ Array[Slot, n]]], dvs] /. HoldComplete[x_] \
:> x]]\"\>"}], ",", 
   RowBox[{"\<\"OverlappingSequences\"\>", 
    "\[Rule]", \
"\<\"PythagoreanPrimes[n_]/;IntegerQ[n]&&n>2:=Select[Prime[Range[PrimePi[n]]],\
Mod[#,4]==1&]\\nPythagoreanPrimes[_]:={}\"\>"}], ",", 
   RowBox[{"\<\"WordsFromWords\"\>", 
    "\[Rule]", \
"\<\"Varignon[{{ax_?NumericQ,ay_?NumericQ},{bx_?NumericQ,by_?NumericQ},{cx_?\
NumericQ,cy_?NumericQ},{dx_?NumericQ,dy_?NumericQ}}]:=Abs[((cx-ax)(dy-by)-(cy-\
ay)(dx-bx))/2]\"\>"}], ",", 
   RowBox[{"\<\"OnTheCriticalLine\"\>", 
    "\[Rule]", "\<\"RATS[k_Integer?Positive, n_Integer?Positive] := \
NestList[FromDigits@Sort@IntegerDigits[# + \
FromDigits[Reverse[IntegerDigits[#]]]] &, k, n - 1]\"\>"}], ",", 
   RowBox[{"\<\"MirrorMirror\"\>", 
    "\[Rule]", "\<\"ClosestNiceRectangle[area_Integer?Positive, \
aspect_Integer?Positive] := \\n Module[{best = None, f = 0, vals, cand},\\n  \
While[True,\\n   vals = DeleteDuplicates@Join[{area - f}, If[f == 0, {}, \
{area + f}]];\\n   cand = Reap[\\n      Do[\\n       If[n > 0,\\n        \
With[{s = Ceiling[Sqrt[n/aspect]], t = Floor[Sqrt[n}]},\\n         Do[\\n     \
     If[e >= 1 && e <= Quotient[n, e] && Quotient[n, e]/e <= aspect && Mod[n, \
e] == 0,\\n           Sow[{Quotient[n, e], e, area - n}]\\n          ],\\n    \
      {e, Union[{s, t}]}\\n         ]\\n        ]\\n       ],\\n       {n, \
vals}\\n      ]\\n     ][[2]];\\n   If[cand =!= {},\\n    best = \
First@SortBy[First@cand, {Abs[#[[3]]], aspect - #[[1]]/#[[2]]} &];\\n    \
Break[]\\n   ];\\n   f++\\n  ];\\n  best\\n ]\"\>"}], ",", 
   RowBox[{"\<\"AnglesOfA3DTriangle\"\>", 
    "\[Rule]", "\<\"RemoveIdenticalNeighbors[l_List] := Flatten@Split[l, \
Unequal]\"\>"}], ",", 
   RowBox[{"\<\"PlanesInSpace\"\>", 
    "\[Rule]", "\<\"DropSeenCharacters[str_String] := \
StringJoin@DeleteDuplicates@Characters[str]\"\>"}], ",", 
   RowBox[{"\<\"NormalFormOfAPlane\"\>", 
    "\[Rule]", "\<\"RepeatFreeSequence[n_Integer?Positive] := \
Nest[Flatten[Table[Append[#, d], {#, #1}, {d, DeleteCases[{0, 1, 2}, \
Last[#]]}], 1] &, List /@ {0, 1, 2}, n - 1]\"\>"}], ",", 
   RowBox[{"\<\"NearestNumbers\"\>", 
    "\[Rule]", \
"\<\"StringExpand[str_String]:=StringJoin@MapIndexed[StringRepeat[#1,First[#2]\
]&,Characters[str]]\"\>"}], ",", 
   RowBox[{"\<\"AllParentheticalExpressions\"\>", 
    "\[Rule]", "\<\"ReverseWords[sentence_String] := StringReplace[sentence, \
RegularExpression[\\\"[A-Za-z0-9]+\\\"] :> StringReverse[\\\"$0\\\"]]\"\>"}], 
   ",", 
   RowBox[{"\<\"Flutter\"\>", 
    "\[Rule]", \
"\<\"ShorterInRomanNumeralsList[n_Integer?Positive]:=Select[Range[n],\
StringLength[ToString[RomanNumeral[#]]]<IntegerLength[#]&]\"\>"}], ",", 
   RowBox[{"\<\"DiagonalsOfRule30\"\>", 
    "\[Rule]", "\<\"RomanEquivalents[n_Integer?Positive] := Module[{r = \
Characters@ToLowerCase@IntegerString[n, \\\"RomanVariant\\\"], c},\\n  c = \
Counts[r];\\n  Count[ToLowerCase /@ WordList[], w_ /; StringLength[w] == \
Length[r] && Counts[Characters[w]] === c]\\n]\"\>"}], ",", 
   RowBox[{"\<\"MinimalCellularAutomaton\"\>", 
    "\[Rule]", "\<\"Rotodromes[n_Integer?Positive] := \
Sort@Select[Select[WordList[], StringLength[#] > n &], With[{r = \
StringRotateRight[#, n]}, r =!= # && DictionaryWordQ[r]] &]\"\>"}], ",", 
   RowBox[{"\<\"PrimeBase\"\>", 
    "\[Rule]", "\<\"RoughSplit[evenbase_Integer?EvenQ, \
exponent_Integer?Positive, cutoff_Integer?Positive] := Module[\\n  {primes, \
modData, residues, x = 1},\\n  primes = Prime[Range[PrimePi[cutoff - 1]]];\\n \
 If[primes === {}, Return[1]];\\n  modData = Table[\\n    With[{p = q, h = \
Mod[PowerMod[evenbase, exponent, 2 q] Quotient[2 q, 2], q]},\\n      {p, \
Mod[h, p], Mod[-h, p]}\\n    ],\\n    {q, primes}\\n  ];\\n  residues = \
AssociationThread[primes, modData[[All, {2, 3}]]];\\n  While[\\n    \
AnyTrue[primes, MemberQ[residues[#], Mod[x, #]] &],\\n    x++\\n  ];\\n  \
x\\n]\"\>"}], ",", 
   RowBox[{"\<\"LongestGraphCycle\"\>", 
    "\[Rule]", "\<\"OneZero[n_Integer?Positive]:=Boole[IntegerQ[(Sqrt[8 \
n-7]-1)/2]]\"\>"}], ",", 
   RowBox[{"\<\"AverageElevation\"\>", 
    "\[Rule]", "\<\"FindInPi[s_String] := FindInPi[s] = Module[{n = 1000000, \
str},\\n  str = StringJoin @@ ToString /@ RealDigits[Pi, 10, n + 1][[1]];\\n  \
With[{p = StringPosition[str, s, 1]},\\n    If[p === {}, -1, p[[1, 1]] - \
1]\\n  ]\\n]\"\>"}], ",", 
   RowBox[{"\<\"BreakingTheCaesarCipher\"\>", 
    "\[Rule]", "\<\"ShortestWordWith[letters_List]:=Module[{req,words,cands},\
\\nreq=Counts@ToLowerCase@letters;\\nwords=Select[WordList[],StringMatchQ[#,\
LetterCharacter..]&];\\ncands=Select[words,With[{cnt=Counts@Characters@\
ToLowerCase@#},And@@KeyValueMap[Lookup[cnt,#1,0]>=#2&,req]]&];\\nIf[cands==={}\
,\\\"\\\",First@SortBy[cands,{StringLength,ToLowerCase}]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"ButterfliedStrings\"\>", 
    "\[Rule]", "\<\"Silverman[n_Integer?Positive] := Module[{res = \
ConstantArray[0, n], i = 1, v = 1, c},\\n  While[i <= n,\\n    c = If[v == 1, \
1, res[[v]]];\\n    res[[i ;; Min[n, i + c - 1]]] = v;\\n    i += c;\\n    \
v++\\n  ];\\n  res\\n]\"\>"}], ",", 
   RowBox[{"\<\"CompositeNumber\"\>", 
    "\[Rule]", \
"\<\"SingleDigitNumbers[n_Integer?Positive,b_Integer/;b>1]:=Sort@\
DeleteDuplicates@Flatten@Table[d*(b^k-1)/(b-1),{k,1,Floor[Log[b,(b-1)n+1]]},{\
d,1,Min[b-1,Floor[n(b-1)/(b^k-1)]]}]\"\>"}], ",", 
   RowBox[{"\<\"CountingLatticePaths\"\>", 
    "\[Rule]", "\<\"SpellWithElements[s_String] := Module[{w = \
ToLowerCase[s], syms, grp, f},\\n  syms = ToLowerCase /@ ElementData[All, \
\\\"Abbreviation\\\"];\\n  grp = GroupBy[syms, StringTake[#, 1] &];\\n  \
Clear[f];\\n  f[i_] := f[i] = If[i > StringLength[w], {{}},\\n    Flatten[\\n \
     Prepend[#, ToUpperCase@StringTake[sym, 1] <> StringDrop[sym, 1]] & /@ \
\\n        f[i + StringLength[sym]] & /@ \\n        Select[Lookup[grp, \
StringTake[w, {i}], {}], StringStartsQ[StringDrop[w, i - 1], #] &],\\n      1\
\\n    ]\\n  ];\\n  Sort[f[1]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"CountingTwinPrimePairs\"\>", 
    "\[Rule]", "\<\"SquarefreeTernarySequence[n_Integer?Positive] := \
Module[{extend},\\n  extend[s_] := Select[Append[s, #] & /@ Range[0, 2], \
Function[t, AllTrue[Range[Floor[Length[t]/2]], t[[-2 # ;; -# - 1]] =!= t[[-# \
;;]] &]]];\\n  If[n < 2, {}, Nest[Flatten[extend /@ #, 1] &, {{0, 1}}, n - \
2]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"CountPalindromicSubstrings\"\>", 
    "\[Rule]", "\<\"SquareRootFloor[n_Integer] := FromDigits /@ \
(Floor[Sqrt[IntegerDigits[#]]] & /@ Range[n])\"\>"}], ",", 
   RowBox[{"\<\"CountTheNumberOfSquares\"\>", 
    "\[Rule]", \
"\<\"SquareSequence[n_Integer?Positive]:=Module[{squares,adj,order,path={},\
used,search,res},\\n squares=Range[2,Floor[Sqrt[2 n]]]^2;\\n \
adj=Table[Select[squares-i,1<=#<=n&&#!=i&],{i,n}];\\n \
order=Reverse@SortBy[Range[n],Length[adj[[#]]]&];\\n \
used=ConstantArray[False,n];\\n search[]:=If[Length[path]==n,True,\\n   \
Module[{cand},\\n    \
cand=Select[If[path==={},order,adj[[Last[path]]]],!used[[#]]&];\\n    \
cand=SortBy[cand,{Length[Select[adj[[#]],!used[[#2]]&]]&,RandomReal[]&}];\\n  \
  Catch[\\n     Do[\\n      used[[v]]=True;AppendTo[path,v];\\n      \
If[search[],Throw[True]];\\n      used[[v]]=False;path=Most[path],\\n      \
{v,cand}\\n     ];\\n     False\\n    ]\\n   ]\\n  ];\\n res=search[];\\n \
If[TrueQ[res],path,{}]\\n]\"\>"}], ",", 
   RowBox[{"\<\"DigitalClockArithmetic\"\>", 
    "\[Rule]", "\<\"SquareSum[n_Integer] /; n > 0 := Fold[(#1 + #2)^2 &, 1 + \
2, Range[3, n]]\"\>"}], ",", 
   RowBox[{"\<\"DigitalRoot\"\>", 
    "\[Rule]", \
"\<\"SteinerInellipseArea[pts:{{_,_},{_,_},{_,_}}]:=Module[{z,p,s1,s2,c,d2,a2,\
b2},\\nz=pts.{1,I};\\np=FromDigits[Reverse[z],x];\\n{s1,s2}=x/.NSolve[D[p,x]==\
0,x];\\nc=Mean[z];\\nd2=Abs[s1-c]^2;\\na2=2 \
Total[Abs[z-c]^2]/3-d2;\\nb2=a2-d2;\\nN[Pi Sqrt[a2 b2]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"FourPileNim\"\>", 
    "\[Rule]", "\<\"PossibleSumFactors[n_Integer, L_List] := Module[{coins = \
ReverseSort @ DeleteDuplicates @ Select[L, IntegerQ[#] && # > 0 &], f},\\n  \
f[0, _] = {{}};\\n  f[_, {}] = {};\\n  f[s_, c : {a_, rest___}] := f[s, c] = \
Join @@ Table[\\n     If[s - k a >= 0,\\n      Prepend[#, Sequence @@ \
ConstantArray[a, k]] & /@ f[s - k a, {rest}],\\n      {}\\n     ],\\n     {k, \
Quotient[s, a], 0, -1}\\n   ];\\n  f[n, coins]\\n]\"\>"}], ",", 
   RowBox[{"\<\"FridayThe13thsInAYear\"\>", 
    "\[Rule]", "\<\"InvertString[s_String] := StringReplace[s, c : \
LetterCharacter :> With[{u = ToUpperCase[c]}, If[c === u, ToLowerCase[c], \
u]]]\"\>"}], ",", 
   RowBox[{"\<\"GrayCode\"\>", 
    "\[Rule]", \
"\<\"MaximumUnattainable[{x_Integer?Positive,y_Integer?Positive}]:=If[\
CoprimeQ[x,y],x y-x-y,Infinity]\"\>"}], ",", 
   RowBox[{"\<\"GrayscaleSpectrum\"\>", 
    "\[Rule]", \
