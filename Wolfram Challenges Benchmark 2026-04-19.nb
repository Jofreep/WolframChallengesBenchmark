   RowBox[{"\<\"RoughGoldbachSplits\"\>", 
    "\[Rule]", "\<\"TwoAndThreePointers[n_Integer] /; n > 0 := \
Sort[Table[Join[ConstantArray[2, a], ConstantArray[3, b]], {b, 0, Quotient[n, \
