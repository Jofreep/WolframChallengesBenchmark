   RowBox[{"\<\"NumberOfVowels\"\>", 
    "\[Rule]", "\<\"PrimePowerPi[x_?Positive] := Module[{n = Floor[x], exps},\
\\n  If[n < 2, 0,\\n   exps = Range[2, Floor[Log[2, n]]];\\n   PrimePi[n] + \
