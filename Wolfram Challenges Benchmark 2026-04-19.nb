Mod[half, #] & /@ primes;\\n  Do[\\n   If[And @@ MapThread[Mod[#1 + x, #2] != \
0 && Mod[#1 - x, #2] != 0 &, {hm, primes}],\\n    Return[x]],\\n   {x, 1, \
Infinity}]\\n ]\"\>", 
   ",", "\<\"OneZero[n_Integer?Positive] := Boole[IntegerQ[Sqrt[8 n + \
1]]]\"\>", 
   ",", "\<\"FindInPi[s_String] := Module[{digits, seq, pos},\\n  digits = \
