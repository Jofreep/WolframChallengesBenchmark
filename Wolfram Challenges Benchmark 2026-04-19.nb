 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "codeExtract", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"codeExtract", "[", "text_String", "]"}], " ", ":=", " ", 
  RowBox[{"Replace", "[", "\n", "  ", 
   RowBox[{
    RowBox[{"StringCases", "[", "\n", "    ", 
     RowBox[{"text", ",", "\n", "    ", 
      RowBox[{
       RowBox[{"\"\<```\>\"", " ", "~~", " ", 
        RowBox[{"(", 
         RowBox[{"\"\<wl\>\"", " ", "|", " ", "\"\<wolfram\>\"", " ", "|", 
          " ", "\"\<mathematica\>\"", " ", "|", 
          " ", "\"\<wollframlanguage\>\""}], ")"}], " ", "~~", "\n", "      ", 
        RowBox[{"WhitespaceCharacter", " ", "..."}], " ", "~~", " ", 
        RowBox[{"Shortest", "[", "x__", "]"}], " ", "~~", 
        " ", "\"\<```\>\""}], " ", ":>", " ", 
       RowBox[{"StringTrim", "[", "x", "]"}]}]}], "\n", "  ", "]"}], ",", 
    "\n", "  ", 
    RowBox[{"{", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{"{", "}"}], " ", ":>", " ", "text"}], ",", "\n", "    ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"___", ",", " ", "x_"}], "}"}], " ", ":>", " ", "x"}]}], "\n",
      "  ", "}"}]}], "\n", "]"}]}]}], "Code",
 CellChangeTimes->{
  3.983504368432179*^9, {3.983504434593123*^9, 3.983504439295556*^9}},
