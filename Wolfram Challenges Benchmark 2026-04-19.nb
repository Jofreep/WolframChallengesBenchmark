   ",", "\<\"BilliardPolygon[poly_, start_, dir_, bounces_] := Module[\\n  {p \
= N[poly], pt = N[start], v = N[dir - start], n, edges, tol = 10.^-6, res, \
step, ints, ts, hit, e, a, b, t, q, u, w},\\n  n = Length[p];\\n  edges = \
Table[{p[[i]], p[[Mod[i, n] + 1]]}, {i, n}];\\n  res = {pt};\\n  Do[\\n    \
ints = Reap[\\n      Do[\\n        a = edges[[i, 1]];\\n        b = edges[[i, \
2]];\\n        u = b - a;\\n        w = a - pt;\\n        If[Abs[Det[{v, u}]] \
> 10.^-14,\\n          t = Det[{w, u}]/Det[{v, u}];\\n          q = Det[{w, \
v}]/Det[{v, u}];\\n          If[t > 10.^-12 && -10.^-12 <= q <= 1 + 10.^-12, \
Sow[{t, Clip[q, {0., 1.}], i}]]\\n        ],\\n        {i, n}\\n      ]\\n    \
][[2]];\\n    If[ints === {} || ints[[1]] === {}, Break[]];\\n    ts = \
SortBy[ints[[1]], First];\\n    hit = First[ts];\\n    t = hit[[1]];\\n    q \
= hit[[2]];\\n    e = hit[[3]];\\n    a = edges[[e, 1]];\\n    b = edges[[e, \
2]];\\n    pt = pt + t v;\\n    AppendTo[res, pt];\\n    If[Min[Norm[pt - #] \
& /@ p] < tol, Break[]];\\n    u = b - a;\\n    If[q < tol || 1 - q < tol, \
Break[]];\\n    v = v - 2 (v.{-u[[2]], u[[1]]})/({-u[[2]], u[[1]]}.{-u[[2]], \
u[[1]]}) {-u[[2]], u[[1]]};\\n    ,\\n    {bounces}\\n  ];\\n  \
N[res]\\n]\"\>", 
