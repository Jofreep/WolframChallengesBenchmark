\"]]}, c =!= {} && Last[c] == 0 && Min[c] >= 0 || p == \\\"\\\"]\"\>"}], ",", 
   
   RowBox[{"\<\"LargeIntegersMod2027\"\>", 
    "\[Rule]", "\<\"Vigenere[plaintext_String, keyword_String] /; \
StringFreeQ[ToUpperCase@keyword, Except[Alternatives @@ \
CharacterRange[\\\"A\\\", \\\"Z\\\"]]] := Module[\\n  {p = \
ToCharacterCode@StringCases[ToUpperCase@plaintext, LetterCharacter], k = \
ToCharacterCode@ToUpperCase@keyword},\\n  FromCharacterCode[65 + Mod[(p - 65) \
+ Take[Flatten@ConstantArray[k - 65, Ceiling[Length[p]/Length[k]]], \
Length[p]], 26]]\\n]\"\>"}], ",", 
   RowBox[{"\<\"LengthOfTheCollatzSequence\"\>", 
    "\[Rule]", "\<\"WaterInBarrel[R_, L_, h_] /; 0 <= h <= 2 R && L >= 0 := \
Module[{a},\\n  a = If[h <= R,\\n    R^2 ArcCos[(R - h)/R] - (R - h) Sqrt[2 R \
h - h^2],\\n    Pi R^2 - (R^2 ArcCos[(h - R)/R] - (h - R) Sqrt[2 R h - \
h^2])\\n  ];\\n  L a\\n]\"\>"}], ",", 
   RowBox[{"\<\"LongestReversedSequence\"\>", 
    "\[Rule]", "\<\"StartsWith[prefix_String] := Select[WordList[], \
StringStartsQ[prefix]]\"\>"}], ",", 
   RowBox[{"\<\"MagicSquares\"\>", 
    "\[Rule]", "\<\"NearestCapitalByLatitude[lat_?NumericQ] /; -90 <= lat <= \
90 := Module[{countries, caps, data, nearest},\\n  countries = \
EntityList[\\\"Country\\\"];\\n  caps = EntityValue[countries, \
\\\"CapitalCity\\\"];\\n  data = Cases[\\n    Transpose[{caps, \
EntityValue[caps, \\\"Latitude\\\"]}],\\n    {c_Entity, q_Quantity} :> \
{UnitConvert[q, \\\"AngularDegrees\\\"] // QuantityMagnitude, c}\\n  ];\\n  \
nearest = Nearest[data[[All, 1]] -> data[[All, 2]], lat, 1][[1]];\\n  \
EntityValue[nearest, \\\"Name\\\"]\\n]\"\>"}], ",", 
   RowBox[{"\<\"MaximalContiguousSum\"\>", 
    "\[Rule]", "\<\"TelephoneWords[digits : {__Integer?(2 <= # <= 9 &)}] := \
Module[\\n  {s, chars, map},\\n  s = ToString /@ digits;\\n  chars = \
Characters[\\\"abcdefghijklmnopqrstuvwxyz\\\"];\\n  map = \
AssociationThread[\\n    chars,\\n    \
Characters[\\\"22233344455566677778889999\\\"]\\n  ];\\n  \
DictionaryLookup[\\n    StringExpression @@ (Alternatives @@ Keys@Select[map, \
# == #2 &] & @@@ Thread[{s, s}]),\\n    IgnoreCase -> True\\n  ] /. x_String \
:> ToLowerCase[x]\\n]\"\>"}], ",", 
   RowBox[{"\<\"MaximumOverhang\"\>", 
    "\[Rule]", "\<\"AntipodeAboveSeaLevelQ[loc_] := Module[{p, a, e},\\n  p = \
Quiet@GeoPosition[loc];\\n  If[! MatchQ[p, GeoPosition[{{_?NumericQ, \
_?NumericQ} ..}] | GeoPosition[{_?NumericQ, _?NumericQ}]], \
Return[$Failed]];\\n  a = GeoDestination[p, {Quantity[20003.93, \
\\\"Kilometers\\\"], 0}];\\n  e = Quiet@GeoElevationData[a];\\n  \
TrueQ[NumericQ[e] && e > 0]\\n]\"\>"}], ",", 
   RowBox[{"\<\"MostRomanNumerals\"\>", 
    "\[Rule]", \
"\<\"FlipPrimeQ[n_Integer?Positive]:=Module[{r=Association[\\\"0\\\"->\\\"0\\\
\",\\\"1\\\"->\\\"1\\\",\\\"2\\\"->\\\"5\\\",\\\"3\\\"->\\\"3\\\",\\\"5\\\"->\
\\\"2\\\",\\\"8\\\"->\\\"8\\\"],s,f},\\nIf[!PrimeQ[n],False,\\ns=Characters[\
ToString[n]];\\nIf[!SubsetQ[Keys[r],s],False,\\nf=FromDigits[StringJoin[\
