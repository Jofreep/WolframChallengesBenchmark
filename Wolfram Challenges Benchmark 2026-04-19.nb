   RowBox[{"\<\"OneFingerDistance\"\>", 
    "\[Rule]", \
"\<\"MaxRomanLength[n_Integer?Positive]:=Max[StringLength[RomanNumeral[Range[\
n]]]]\"\>"}], ",", 
   RowBox[{"\<\"PalindromeFromAWord\"\>", 
    "\[Rule]", "\<\"MostOccurringWeekday[year_Integer] := Module[{counts},\\n \
 counts = Counts[DayName /@ DateRange[{year, 1, 1}, {year, 12, 31}, \\\"Day\\\
\"]];\\n  Keys@Select[counts, # == Max[counts] &]\\n]\"\>"}], ",", 
   RowBox[{"\<\"PigLatin\"\>", 
