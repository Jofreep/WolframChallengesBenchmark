:= {};\\n  helper[rem_, coins_List] := Module[{c = First[coins], rest = \
Rest[coins]},\\n    Join @@ Table[\\n      Map[Join[Table[c, k], #] &, \
helper[rem - k*c, rest]],\\n      {k, 0, Floor[rem/c]}\\n    ]\\n  ];\\n  \
ReverseSort /@ helper[n, sorted]\\n]\"\>"}], ",", 
