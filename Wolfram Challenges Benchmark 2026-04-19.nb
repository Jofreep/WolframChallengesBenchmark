@Thread[Total[{a,b,c}]-{a,b,c}>{a,b,c}]\"\>"}], ",", 
   RowBox[{"\<\"HowRoundIsACountry\"\>", 
    "\[Rule]", "\<\"ValidParentheses[p_String] := Module[{c = \
