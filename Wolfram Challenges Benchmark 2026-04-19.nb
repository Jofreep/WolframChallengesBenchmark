   ",", "\<\"NextPermutation[p:{__Integer}] := Module[{n = Length[p], lst = \
p, i, j, sorted},\\n  (* Find largest i such that lst[[i]] < lst[[i+1]] *)\\n \
 i = n - 1;\\n  While[i >= 1 && lst[[i]] >= lst[[i + 1]], i--];\\n  If[i == \
0,\\n    (* Last permutation: return first (sorted) *)\\n    Sort[lst],\\n    \
(* Find largest j > i such that lst[[j]] > lst[[i]] *)\\n    j = n;\\n    \
While[lst[[j]] <= lst[[i]], j--];\\n    (* Swap lst[[i]] and lst[[j]] *)\\n   \
 {lst[[i]], lst[[j]]} = {lst[[j]], lst[[i]]};\\n    (* Reverse the suffix \
from i+1 to n *)\\n    lst = Join[lst[[1 ;; i]], Reverse[lst[[i + 1 ;; \
n]]]]\\n  ]\\n]\"\>", 
