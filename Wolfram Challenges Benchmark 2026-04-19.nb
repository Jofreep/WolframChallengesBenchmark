"\<\"LongestReversedSubsequence[list:{__Integer}]:=Module[{n=Length[list],dp,\
i,j},\\ndp=ConstantArray[0,{n,n}];\\nDo[\\ndp[[i,i]]=1;\\n,{i,n}];\\nDo[\\nIf[\
list[[i]]===list[[j]],\\ndp[[i,j]]=If[i+1<=j-1,dp[[i+1,j-1]],0]+2,\\ndp[[i,j]]\
=Max[dp[[i+1,j]],dp[[i,j-1]]]\\n];\\n,{d,1,n-1},{i,1,n-d};j=i+d];\\ndp[[1,n]]\
\\n]\"\>", 
