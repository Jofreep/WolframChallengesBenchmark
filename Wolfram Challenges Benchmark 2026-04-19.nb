   RowBox[{"\<\"SilvermansSequence\"\>", 
    "\[Rule]", "\<\"MagicSquareQ[matrix_] /; Equal @@ Dimensions[matrix] := \
Module[\\n  {n = Length[matrix], target, flat},\\n  flat = \
Flatten[matrix];\\n  Sort[flat] === Range[n^2] &&\\n  (target = n (n^2 + 1) / \
2;\\n   AllTrue[Total /@ matrix, # == target &] &&\\n   AllTrue[Total /@ \
Transpose[matrix], # == target &] &&\\n   Total[Diagonal[matrix]] == target \
&&\\n   Total[Diagonal[Reverse[matrix]]] == target)\\n]\"\>"}], ",", 
