   RowBox[{"\<\"BalancedTernary\"\>", 
    "\[Rule]", "\<\"LatticeBallCount[r_ /; 0 < r <= 200] := Module[{r2, count \
= 0, n, rem, zmax},\\n  r2 = r^2;\\n  n = Floor[r];\\n  Do[\\n    rem = r2 - \
x^2 - y^2;\\n    If[rem < 0, Continue[]];\\n    zmax = Floor[Sqrt[rem]];\\n   \
 (* Correct floor of sqrt for potential floating point issues *)\\n    \
While[(zmax + 1)^2 <= rem, zmax++];\\n    While[zmax^2 > rem, zmax--];\\n    \
count += 2 zmax + 1;,\\n    {x, -n, n}, {y, -n, n}\\n  ];\\n  \
count\\n]\"\>"}], ",", 
