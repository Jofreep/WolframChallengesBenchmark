n = Length[pts];\\n  \\n  sa = Total[Table[\\n    pts[[i, 1]] pts[[Mod[i, n] \
+ 1, 2]] - pts[[Mod[i, n] + 1, 1]] pts[[i, 2]],\\n    {i, n}]];\\n  If[sa < \
