Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "the", " ", "dataset"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"data", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"23", ",", " ", "37", ",", " ", "105"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"labels", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<GPT-4\>\"", ",", " ", "\"\<GPT-5.4\>\"", ",", 
       " ", "\"\<Claude Opus 4.6\>\""}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Define", " ", "the", " ", "color", " ", "palette"}], " ", "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"colors", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RGBColor", "[", "\"\<#8E8E93\>\"", "]"}], ",", " ", 
       RowBox[{"RGBColor", "[", "\"\<#007AFF\>\"", "]"}], ",", " ", 
       RowBox[{"RGBColor", "[", "\"\<#FF9500\>\"", "]"}]}], "}"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"FIX", ":", " ", 
     RowBox[{
      RowBox[{
      "Map", " ", "labels", " ", "perfectly", " ", "to", " ", "the", " ", 
       "Y"}], "-", 
      RowBox[{"axis", " ", "positions"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"yTicks", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"labels", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", " ", "14", ",", " ", "Bold", 
           ",", " ", 
           RowBox[{"FontFamily", " ", "->", " ", "\"\<Helvetica\>\""}]}], 
          "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "labels", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Generate", " ", "the", " ", "infographic"}], " ", "*)"}], "\n", 
   RowBox[{"BarChart", "[", "\n", "  ", 
    RowBox[{"data", ",", "\n", "  ", 
     RowBox[{"BarOrigin", " ", "->", " ", "Left"}], ",", "\n", "  ", 
     RowBox[{"ChartStyle", " ", "->", " ", "colors"}], ",", "\n", "  ", 
     RowBox[{"BarSpacing", " ", "->", " ", "0.3"}], ",", "\n", "  ", "\n", 
     "  ", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Format", " ", "data", " ", "labels", " ", "cleanly", " ", "to", " ", 
       "the", " ", "right", " ", "of", " ", "the", " ", "bars"}], " ", "*)"}],
      "\n", "  ", 
     RowBox[{"LabelingFunction", " ", "->", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Placed", "[", "\n", "      ", 
