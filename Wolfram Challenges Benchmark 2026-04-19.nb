{}]]], OrderedQ[{Length[#1], #1}, {Length[#2], #2}] &]\"\>"}], ",", 
   RowBox[{"\<\"SeparateOnesByZeros\"\>", 
    "\[Rule]", "\<\"PrimePalindromePi[n_Integer] := Module[{k, count = 0, m, \
s},\\n  If[n < 2, Return[0]];\\n  If[n >= 2, count++];\\n  If[n >= 3, \
count++];\\n  If[n >= 5, count++];\\n  If[n >= 7, count++];\\n  If[n >= 11, \
count++];\\n  k = 2;\\n  While[True,\\n    s = ToString[k];\\n    m = \
FromDigits[StringJoin[s, StringReverse[Most[Characters[s]]]]];\\n    If[m > \
n, Break[]];\\n    If[PrimeQ[m], count++];\\n    k++\\n  ];\\n  \
count\\n]\"\>"}], ",", 
   RowBox[{"\<\"SequenceHuntInPi\"\>", 
