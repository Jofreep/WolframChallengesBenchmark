pairs={};\\n  Do[\\n    If[MemberQ[sums,sorted[[i]]+sorted[[j]]],\\n      \
AppendTo[pairs,{i,j}]\\n    ],\\n    {i,1,n},{j,i+1,n}\\n  ];\\n  (* Model as \
