    RowBox[{"\"\<```wolfram\\nAliquotSequence[num_Integer?Positive] := \
NestWhileList[DivisorSigma[1, #] - # &, num, With[{seen = Internal`Bag[]}, \
(Internal`StuffBag[seen, #]; # > 1 && !MemberQ[Internal`BagPart[seen, All], \
