Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"descriptions", "=", 
  RowBox[{
   RowBox[{"ResourceFunction", "[", "\"\<WolframChallengesData\>\"", "]"}], "[", 
   RowBox[{"\"\<Keys\>\"", "->", "\"\<Description\>\""}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9855592521143827`*^9, 3.9855592521144753`*^9}},
 CellLabel->
  "In[2755]:=",ExpressionUUID->"daf40dbf-b05c-485c-b0ae-ea41bbb61ec4"],

Cell[BoxData[
 TagBox[
  TagBox[
   DynamicModuleBox[{TypeSystem`NestedGrid`PackagePrivate`$state$$ = <|
    "InitialData" -> <|
      "Aliquot Sequence" -> <|
        "Description" -> 
         "In an aliquot sequence, each term is the sum of the proper divisors \
of the previous term. Write a function that finds the aliquot sequence \
starting with a given positive integer. Stop at 1 or before a term is \
repeated."|>, 
       "All Parenthetical Expressions" -> <|
        "Description" -> 
         "Generate all possible matched sequences of opened and closed \
parentheses of <i>n</i> pairs."|>, 
       "Almost Palindromes" -> <|
        "Description" -> 
         "Write a function that finds words that would be palindromes if one \
of their letters was removed."|>, 
       "Almost Repeating Primes" -> <|
        "Description" -> 
         "Find primes that start with a repeated base-10 digit, followed by a \
single digit at the end."|>, 
       "Anagram Words" -> <|
        "Description" -> 
         "An anagram is a word or phrase created by rearranging the letters \
of another word or phrase. Write a function that takes a word and uses the \
dictionary to return a list of anagrams."|>, 
       "Angles of a 3D Triangle" -> <|
        "Description" -> 
         "Given three points in 3D space, determine the angles (in degrees) \
of the triangle they form."|>, 
       "Antipodal City" -> <|
        "Description" -> 
         "Find the city that is closest to the antipode of a given location \
on Earth."|>, 
       "Antipode above or below Sea Level" -> <|
        "Description" -> 
         "Find whether the antipode of a point on Earth is above sea \
level."|>, 
       "Ascending Sublists" -> <|
        "Description" -> 
         "In a given unsorted list, find the maximal ascending sublists of at \
least two contiguous elements."|>, 
       "Average Elevation" -> <|
        "Description" -> 
         "Write a function to find the average elevation over a specified \
latitude."|>, 
       "Babbage Squares" -> <|
        "Description" -> 
         "A Babbage square is a grid of letters that reads the same across as \
it does down. Given a four-letter word, find all Babbage squares starting \
with that word."|>, 
       "Balanced Ternary" -> <|
        "Description" -> "Represent a number in balanced ternary."|>, 
       "Base-b Palindromic Numbers" -> <|
        "Description" -> 
         "Write a function that finds the positive integers up to 1000 that \
are palindromes in base <i>b</i>."|>, 
       "Breaking the Caesar Cipher" -> <|
        "Description" -> 
         "The Caesar shift cipher encrypts a message by replacing each letter \
with a letter some fixed distance away from it in the alphabet. Write a \
function to decrypt a message that was enciphered using a Caesar shift."|>, 
       "Bubble Sort" -> <|
        "Description" -> 
         "Write a function that shows the steps performed in a bubble \
sort."|>, 
       "Butterflied Strings" -> <|
        "Description" -> "Join a string with its reversal."|>, 
       "Capital Cities Near a Latitude" -> <|
        "Description" -> 
         "Write a function that finds the capital city closest to a given \
latitude."|>, 
       "Carry Counting" -> <|
        "Description" -> 
         "Given two positive integers, compute how many carry operations are \
involved in the standard method for adding them in base 2."|>, 
       "Cellular Automaton" -> <|
        "Description" -> 
         "A cellular automaton is a collection of colored or numbered cells \
on a grid of specified shape that evolves through a number of discrete time \
steps according to a set of rules based on the states of neighboring cells. \
The rules are then applied iteratively for as many time steps as desired."|>, 
       "Cellular Automaton Transients" -> <|
        "Description" -> 
         "Find the length of a transient in a cellular automaton \
evolution."|>, 
       "Color Conversion" -> <|
        "Description" -> 
         "Write code to convert a set of RGB color values to a set of CMYK \
color values."|>, 
       "Combine n Ones" -> <|
        "Description" -> 
         "Write a function to find which numbers can be generated by \
combining <i>n</i> 1s with <a \
href=\"https://reference.wolfram.com/language/ref/Plus\">Plus</a> and <a \
href=\"https://reference.wolfram.com/language/ref/Times\">Times</a> in all \
possible ways."|>, 
       "Composite Number" -> <|
        "Description" -> 
         "Create a function that gives the <i>n</i><sup>th</sup> composite \
number. A composite number <i>x</i> has a proper divisor, that is, a divisor \
different from 1 and <i>x</i> itself."|>, 
       "Constant Digit Sum" -> <|
        "Description" -> 
         "Write a function that finds all of the integers between <i>m</i> \
and <i>n</i> whose digits in base 10 add up to <i>s</i>."|>, 
       "Counting Lattice Paths" -> <|
        "Description" -> 
         "Write a function that takes <i>n</i> as input and outputs the \
number of paths from the upper-left corner to the lower-right corner of an \
<i>n</i>\[Times]<i>n</i> grid of lattice points."|>, 
       "Counting Twin Prime Pairs" -> <|
        "Description" -> 
         "Primes are the multiplicative building blocks of the integers. Twin \
primes throw addition into the mix: they are pairs of primes that differ by \
2. Count the number of twin prime pairs up to <i>n</i>."|>, 
       "Count Palindromic Substrings" -> <|
        "Description" -> 
         "A palindromic string reads the same in either direction. Write a \
function that takes a string and returns the number of its palindromic \
substrings."|>, 
       "Country Chains" -> <|
        "Description" -> 
         "Given two countries, find the length of the shortest chain of \
bordering countries that connects them."|>, 
       "Count the Number of Squares" -> <|
        "Description" -> 
         "Given a subset of points of a rectangular grid, count the number of \
squares of any size and at any angle that can be drawn using those points as \
vertices."|>, 
       "Deriffle a List" -> <|
        "Description" -> 
         "Write a function that takes a list and puts every other entry into \
two different lists."|>, 
       "Diagonals of Rule 30" -> <|
        "Description" -> 
         "Give the <i>n</i>th left and right diagonals of rule 30."|>, 
       "Digital Clock Arithmetic" -> <|
        "Description" -> 
         "Given a time of day, find the number of identities that exist by \
inserting exactly one equal sign between two digits and some choice of +, \
\[Dash], \[Times], \[Divide] between the rest."|>, 
       "Digital Root" -> <|
        "Description" -> 
         "Write a function that finds the digital root of a non-negative \
integer <i>n</i>."|>, 
       "Digit Frequency for Pi" -> <|
        "Description" -> 
         "Pi (\[Pi]) has an infinite decimal expansion starting 3.14159\
\[Ellipsis]. Given the decimal expansion of \[Pi] to <i>n</i> places, write a \
function that returns a list of the count of each digit from 0 to 9 in the \
expansion. "|>, 
       "Discrete Spiral" -> <|
        "Description" -> 
         "Write code to make a spiral of <i>n</i>+1 integer coordinates, \
starting at (0,0)."|>, 
       "Emirps Is Primes Backward" -> <|
        "Description" -> 
         "An \"emirp\" is a prime number that yields a different prime number \
when its digits are reversed. Write a function that outputs all emirps less \
than or equal to a given positive integer."|>, 
       "Factorial Digit Frequency" -> <|
        "Description" -> 
         "Write a function to order the base-10 digits from least common to \
most common among the first <i>n</i> factorials."|>, 
       "Factorial Zeros" -> <|
        "Description" -> 
         "Write a function that finds the number of zeros at the end of the \
decimal expansion of <i>n</i>!."|>, 
       "Factor Trees" -> <|
        "Description" -> 
         "Write a function to create a tree showing the divisors of a number \
down to its prime factors."|>, 
       "Farthest Words" -> <|
        "Description" -> 
         "Find the words in WordList[] that are the maximum distance in \
\"letter space\" away from a given word."|>, 
       "Fewest Number of Coins" -> <|
        "Description" -> 
         "Given a list of values for coins, write a function that finds the \
fewest number of coins needed to add up to a certain value."|>, 
       "Find Goldbach Partitions" -> <|
        "Description" -> 
         "For an even number <i>n</i>>2, a Goldbach partition for that number \
is a pair of primes that add up to <i>n</i>. Write a function to find the \
Goldbach partitions for an even number greater than 2."|>, 
       "Finding Flip Primes" -> <|
        "Description" -> 
         "A positive integer is called a <i>flip number</i> if it can be read \
as a number when flipped upside down in a seven-segment display. A positive \
integer <i>n</i> is called a <i>flip prime</i> if <i>n</i> is a flip number \
and both <i>n</i> and <i>n</i> flipped are prime. Write a function that \
determines if a positive integer is a flip prime."|>, 
       "Five Long Weekends in a Month" -> <|
        "Description" -> 
         "Write a function that finds months containing five long \
weekends."|>, 
       "Five-Point Conic" -> <|
        "Description" -> 
         "Find the conic section going through five given points."|>, 
       "Fizz Buzz" -> <|
        "Description" -> 
         "Given a list of integers from 1 to <i>n</i>, write a function that \
replaces multiples of 3 with \"fizz\", multiples of 5 with \"buzz\", \
multiples of both 3 and 5 with \"fizzbuzz\" and leaves other numbers \
fixed."|>, 
       "Flutter" -> <|
        "Description" -> 
         "Given a function <i>f</i>, an expression <i>x</i> and a list, list \
<i>f</i>[<i>x</i>, <i>y</i>] for all <i>y</i> in the list."|>, 
       "Forbidden Substrings" -> <|
        "Description" -> 
         "Write a function that lists all strings composed of A's and B's \
that do not contain a specified substring."|>, 
       "Four-Pile Nim" -> <|
        "Description" -> 
         "Nim is a two-person game in which players take turns removing any \
number of chips from one of several piles of chips, with the goal of taking \
the last one. Write a function that looks at the state of a game of Nim with \
four piles and returns whether or not the player making the next move has a \
winning strategy."|>, 
       "Four-Point Parabola" -> <|
        "Description" -> 
         "Find two parabolas going through four given points."|>, 
       "Friday the 13ths in a Year" -> <|
        "Description" -> 
         "Write a function to determine how many Friday the 13ths happen in a \
given calendar year."|>, 
       "Getting a Basketball Score" -> <|
        "Description" -> 
         "Write a function that takes an integer <i>n</i> and outputs all the \
possible ways to represent <i>n</i> as sums of 2s and 3s. "|>, 
       "Gray Code" -> <|
        "Description" -> 
         "Write a function that takes an integer and returns its \
corresponding Gray code."|>, 
       "Grayscale Spectrum" -> <|
        "Description" -> 
         "Write a function that takes a list of numbers as input and returns \
a grayscale spectrum with the smallest number corresponding to black, the \
largest number corresponding to white and the rest of the colors scaled \
linearly."|>, 
       "Hash Loop" -> <|
        "Description" -> 
         "Write a function that finds the first number less than 65536 that \
appears periodically in nested modulo 65536 hashes of a given positive \
integer. "|>, 
       "How Round Is a Country?" -> <|
        "Description" -> 
         "Write a function to find out how close the map of a country is to \
being a disk."|>, 
       "Integer Name Lengths" -> <|
        "Description" -> 
         "Write a function that creates a sequence of integers where each \
successive entry is the number of characters needed to spell the previous \
entry. Stop before the sequence repeats a term."|>, 
       "Integers with Given Digit Sums" -> <|
        "Description" -> 
         "Write a function to find all positive integers below 1000 whose \
base-10 digits have a given sum. "|>, 
       "Iterated Roman Numeralization" -> <|
        "Description" -> 
         "Write a function that starts from a number <i>n</i>, finds its \
representation <i>r</i> in Roman numerals, finds the length of <i>r</i> as a \
Roman numeral, and continues, stopping just before a number previously in the \
list comes up again."|>, 
       "Josephus Problem" -> <|
        "Description" -> 
         "Solve the Josephus problem: In a circle of <i>n</i> soldiers, every \
<i>m</i><sup>th</sup> soldier is executed. In what order are the soldiers \
executed?"|>, 
       "Knight Points" -> <|
        "Description" -> 
         "Given a binary image, pick out all pairs of black pixels a knight's \
move away from each other."|>, 
       "Large Integers Mod 2027" -> <|
        "Description" -> 
         "Define a sequence <i>a</i>(<i>n</i>) by the rules \
<i>a</i>(0)=<i>a</i>(1)=1, \
<i>a</i>(<i>n</i>)=(<i>a</i>(<i>n</i>-1)<sup>4</sup>+1)/<i>a</i>(<i>n</i>-2). \
Define a Wolfram Language function to find the <i>n</i><sup>th</sup> term of \
this sequence modulo 2027."|>, 
       "Lattice Points in a Sphere" -> <|
        "Description" -> 
         "How many lattice points are in a ball of a given radius?"|>, 
       "Length of the Collatz Sequence" -> <|
        "Description" -> 
         "Take a positive integer <i>n</i>. If <i>n</i> is even, divide by 2. \
If <i>n</i> is odd, multiply by 3 and add 1. Iterate this procedure to form \
the Collatz sequence. Write a function to find how many steps are needed to \
reach 1 starting from <i>n</i>."|>, 
       "Letter Bank" -> <|
        "Description" -> 
         "Given a set of letters, return the words in WordList[] using only \
those letters."|>, 
       "Listify the Elements of a List" -> <|
        "Description" -> 
         "Write a function that takes a list and replaces its elements with \
\"listified\" versions of themselves."|>, 
       "List Prime Palindromes" -> <|
        "Description" -> 
         "A palindromic prime is a prime number whose base-10 representation \
reads the same in either direction. Write a function that returns a list of \
all palindromic primes less than a given integer <i>n</i>."|>, 
       "Longest Graph Cycle" -> <|
        "Description" -> 
         "Given an undirected graph, find a cycle that visits as many nodes \
as possible."|>, 
       "Longest Reversed Sequence" -> <|
        "Description" -> 
         "In a list of integers, find the longest subsequence whose reverse \
also appears in the list."|>, 
       "Look and Say Sequence" -> <|
        "Description" -> 
         "The \"look and say\" sequence starts with 1. Look at the previous \
term 1 and say what you see, \"one 1\" to get the second term 11. Now look at \
the second term 11 and say, \"two ones\" to get the third term 21. Look at \
the third term 21 and say \"one 2 one 1\" to get the fourth term 1211. This \
gives the sequence 1, 11, 21, 1211, 111221, \[Ellipsis]."|>, 
       "Magic Squares" -> <|
        "Description" -> 
         "A magic square is a square matrix containing all the integers 1 \
through <i>n</i><sup>2</sup> so that each row, column and the two diagonals \
add up to the same sum. Write a function to check if a given matrix is a \
magic square. "|>, 
       "Making Change" -> <|
        "Description" -> 
         "Suppose the coins in circulation are pennies, nickels, dimes, \
quarters, 50-cent pieces and dollar coins, worth 1\[Cent], 5\[Cent], \
10\[Cent], 25\[Cent], 50\[Cent] and $1. How many ways can you make change for \
a given amount using those kinds of coins? "|>, 
       "Maximal Contiguous Sum " -> <|
        "Description" -> 
         "Given a list of integers, find the largest sum of a contiguous \
subsequence."|>, 
       "Maximum Color Distance" -> <|
        "Description" -> 
         "Write a function to find the most perceptually distinct colors in \
an image."|>, 
       "Maximum Overhang" -> <|
        "Description" -> 
         "Given <i>n</i> cards, find the maximum overhang those cards can \
have over the edge of a table."|>, 
       "Maximum Roman Numeral Length" -> <|
        "Description" -> 
         "Write a function that finds the maximum length of any Roman numeral \
up to <i>n</i>."|>, 
       "Minimal Cellular Automaton" -> <|
        "Description" -> 
         "Given a list of 0s and 1s, find the cellular automaton with the \
