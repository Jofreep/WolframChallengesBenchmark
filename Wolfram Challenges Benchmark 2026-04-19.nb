       "Number of Vowels" -> <|
        "Description" -> 
         "Find the number of words in WordList[] that have a given number of \
vowels."|>, 
       "Number Triangles" -> <|
        "Description" -> 
         "Write a function that stacks successively longer lists of integers \
on top of each other."|>, 
       "Odds before Evens" -> <|
        "Description" -> 
         "Given a list of integers, rearrange them so that all of the odd \
integers appear before all of the even integers, without otherwise changing \
the order."|>, 
       "One-Finger Distance" -> <|
        "Description" -> 
         "Given a linear keyboard of the letters of the alphabet, how many \
letters in total does your finger have to jump over in order to type a given \
word?"|>, 
       "On the Critical Line" -> <|
        "Description" -> 
         "Solve the Riemann hypothesis and collect a million dollars."|>, 
       "Overlapping Sequences" -> <|
        "Description" -> 
         "Find all sequences of 0s and 1s of length <i>n</i> for which one \
rotation is the same as some other rotation."|>, 
       "Pairing Compatible Integers" -> <|
        "Description" -> 
         "Write a function that creates all pairs from one list of integers \
that add up to some element of acceptable sums given in another list."|>, 
       "Pairingfunction" -> <|
        "Description" -> 
         "Define a function that maps each non-negative integer coordinate \
pair to a number so that consecutive numbers lie on the falling diagonals in \
the first quadrant."|>, 
       "Pairs That Sum to 100" -> <|
        "Description" -> 
         "Given a list of integers, find all pairs that sum to 100. "|>, 
       "Palindrome from a Word" -> <|
        "Description" -> 
         "Write a function that takes a string and returns the smallest \
possible palindrome beginning with that string."|>, 
       "Palindromes" -> <|
        "Description" -> 
         "A palindrome is a word that is the same when read forward or \
backward. For example, \"radar\" is a palindrome. Write a function that finds \
all the palindromes of a given length <i>n</i> in the dictionary. "|>, 
       "Palindromic Roman Numerals" -> <|
        "Description" -> 
         "A palindromic Roman numeral is a number whose Roman numeral \
representation reads the same in either direction. Write a function that \
returns all numbers (in decimal) up to an integer <i>n</i> that are \
palindromic in Roman numerals."|>, 
       "Pancake Scramble" -> <|
        "Description" -> 
         "There are many ways to scramble a string of text. For a pancake \
scramble, imagine each character of the string as a pancake in a stack. Think \
of the process as repeatedly flipping larger stacks of pancakes until you \
flip the entire stack. Write a function that outputs the pancake scramble of \
a string. "|>, 
       "Pancake Scramble Period" -> <|
        "Description" -> 
         "Write a function that finds the smallest positive number of times \
pancake scramble needs to be applied to get back the original input."|>, 
       "Partitions of Increasing Length" -> <|
        "Description" -> 
         "Write a function that partitions a list so that each sublist is one \
item longer than the previous one."|>, 
       "Permutation Count" -> <|
        "Description" -> 
         "Given an integer, enumerate the numbers formed by permuting its \
digits."|>, 
       "Permutation Index" -> <|
        "Description" -> 
         "Write code to find the <i>k</i><sup>th</sup> permutation from the \
<i>n</i>! permutations of {1,\[Ellipsis],<i>n</i>}."|>, 
       "Pig Latin" -> <|
        "Description" -> 
         "Pig Latin is a language game in which words in English are altered \
according to certain rules. Write a function that converts text written in \
English into Pig Latin."|>, 
       "Planes in Space" -> <|
        "Description" -> 
         "From a set of 3D lattice points, tally the number of planes through \
three or more by the number of points."|>, 
       "Point inside Triangle" -> <|
        "Description" -> 
         "Write code to determine if a given point in the plane is inside a \
given triangle. "|>, 
       "Polygon Billiards" -> <|
        "Description" -> 
         "Given a mirror-sided polygon and an interior ray, determine the \
trajectory of the ray as it bounces off the walls."|>, 
       "Powerful Digit Frequencies" -> <|
        "Description" -> 
         "Given a positive integer <i>n</i>, find the frequencies of the \
digits from 0 to 9 of the number 2<sup><i>n</i></sup>."|>, 
       "Prime Base" -> <|
        "Description" -> 
         "Represent a number by the sum of the smallest possible distinct \
primes."|>, 
       "Prime Fibonacci Numbers" -> <|
        "Description" -> 
         "Write a function that finds all of the prime numbers among the \
first <i>n</i> terms of the Fibonacci sequence."|>, 
       "Prime Gaps" -> <|
        "Description" -> 
         "Find the smallest pair of successive primes that have separation \
<i>n</i>."|>, 
       "Prime Palindrome Pi" -> <|
        "Description" -> 
         "A palindromic prime is a prime number whose base-10 representation \
reads the same in either direction. Write a function that outputs the number \
of palindromic primes less than or equal to <i>n</i>."|>, 
       "Prime Power Pi" -> <|
        "Description" -> 
         "A prime power is a number that is a power of a prime number. For \
example, 8 is a prime power since it is 2 cubed. Write a function that takes \
a positive number <i>x</i> and returns the number of positive prime powers up \
to <i>x</i>."|>, 
       "Pure Function Maker" -> <|
        "Description" -> 
         "For many functions that are defined via Downvalues, it is possible \
to instead use a pure function. In this challenge, your goal is to write a \
function that can convert a symbol to a pure function that exhibits the same \
behavior."|>, 
       "Pythagorean Primes" -> <|
        "Description" -> 
         "A Pythagorean prime is a prime number of the form 4<i>k</i>+1, \
where <i>k</i> is a positive integer. Write a function that takes an integer \
<i>n</i> and returns the list of Pythagorean prime numbers up to <i>n</i>."|>,
        "Quadrilateral Midpoints" -> <|
        "Description" -> 
         "Write code to find the unsigned area of a quadrilateral with \
vertices on the midpoints of a given quadrilateral."|>, 
       "RATS Sequences" -> <|
        "Description" -> 
         "A RATS sequence is a sequence that is produced by the instructions \
